@import url("color-variables.css");

.payroll-history-main {
  margin-top: calc(var(--main-header-height, 0px) + var(--page-content-gap, 0.65rem));
  min-height: calc(100vh - var(--main-header-height, 0px) - var(--main-footer-height, 0px) - var(--page-content-gap, 0.65rem));
  padding: 0 1rem 1.25rem;
}

.payroll-history-shell {
  width: min(1320px, 100%);
  margin: 0 auto;
  display: grid;
  gap: 0.9rem;
}

/* Prevent global styles.css `header { position: fixed; ... }` from hijacking local section headers. */
.payroll-history-header,
.detail-header,
.payroll-modal-header {
  position: static;
  top: auto;
  left: auto;
  right: auto;
  width: auto;
  z-index: auto;
  transform: none;
  animation: none;
}

.payroll-history-header {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: flex-start;
  background: color-mix(in srgb, var(--card-bg) 94%, var(--menu-bg-dark) 6%);
  border: 1px solid var(--border-color);
  border-radius: 14px;
  padding: 0.95rem 1.1rem;
}

.payroll-history-header h1 {
  margin: 0;
  color: var(--heading-color);
  font-size: 1.45rem;
}

.payroll-history-header p {
  margin: 0.25rem 0 0;
  color: var(--muted-color);
  font-size: 0.92rem;
  max-width: 760px;
}

.payroll-history-header-actions {
  display: flex;
  align-items: center;
}

.btn-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.35rem;
  border: 1px solid color-mix(in srgb, var(--border-color) 84%, #ffffff 16%);
  background: linear-gradient(135deg, color-mix(in srgb, var(--card-bg) 82%, var(--menu-bg-dark) 18%) 0%, color-mix(in srgb, var(--card-bg) 90%, var(--menu-bg-dark) 10%) 100%);
  color: var(--heading-color);
  border-radius: 9px;
  font-size: 0.82rem;
  font-weight: 700;
  padding: 0.45rem 0.82rem;
  text-decoration: none;
  cursor: pointer;
  transition: transform 0.18s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  box-shadow: 0 2px 10px color-mix(in srgb, var(--menu-bg-dark) 11%, transparent 89%);
}

.btn-action:hover {
  transform: translateY(-1px);
  border-color: color-mix(in srgb, var(--accent-color) 58%, var(--border-color) 42%);
  box-shadow: 0 8px 16px color-mix(in srgb, var(--primary-blue) 18%, transparent 82%);
}

.btn-action:disabled {
  opacity: 0.58;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.btn-history-back {
  background: linear-gradient(135deg, #0f5cb8 0%, #6f163b 100%);
  border-color: color-mix(in srgb, #0f5cb8 45%, #ffffff 55%);
  color: #ffffff;
  font-size: 0.85rem;
  text-decoration: none;
  white-space: nowrap;
  letter-spacing: 0.01em;
  box-shadow: 0 8px 18px color-mix(in srgb, #0f5cb8 30%, transparent 70%);
}

.btn-history-back:hover {
  border-color: color-mix(in srgb, #0f5cb8 70%, #ffffff 30%);
  background: linear-gradient(135deg, #104a8f 0%, #58132f 100%);
}

.payroll-history-access {
  border: 1px solid color-mix(in srgb, var(--error-color) 55%, transparent 45%);
  background: color-mix(in srgb, var(--error-color) 14%, var(--card-bg) 86%);
  color: var(--heading-color);
  border-radius: 12px;
  padding: 0.75rem 0.9rem;
  font-size: 0.9rem;
}

.hidden {
  display: none !important;
}

.payroll-history-filters {
  display: grid;
  grid-template-columns: auto minmax(110px, 1fr) auto minmax(110px, 1fr) auto minmax(140px, 1fr) auto minmax(100px, 1fr) auto minmax(220px, 2fr) auto;
  align-items: center;
  gap: 0.45rem 0.65rem;
  border: 1px solid var(--border-color);
  border-radius: 12px;
  padding: 0.7rem;
  background: var(--card-bg);
}

.payroll-history-filters label {
  font-size: 0.77rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  color: var(--muted-color);
}

.payroll-history-filters input,
.payroll-history-filters select {
  width: 100%;
  border: 1px solid var(--border-color);
  border-radius: 8px;
  background: var(--input-bg);
  color: var(--input-text);
  padding: 0.45rem 0.5rem;
  font-size: 0.86rem;
}

.payroll-history-filters .btn-action {
  height: 2rem;
  font-size: 0.8rem;
  padding: 0.3rem 0.8rem;
}

.payroll-history-summary {
  display: grid;
  gap: 0.7rem;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
}

.history-stat-card {
  border-radius: 12px;
  border: 1px solid var(--border-color);
  background: var(--card-bg);
  padding: 0.7rem 0.82rem;
  display: grid;
  gap: 0.3rem;
}

.history-stat-card .label {
  font-size: 0.74rem;
  color: var(--muted-color);
  text-transform: uppercase;
  letter-spacing: 0.03em;
  font-weight: 700;
}

.history-stat-card .value {
  font-size: 1.22rem;
  color: var(--heading-color);
  font-weight: 800;
}

.history-stat-card.good {
  border-top: 3px solid #16a34a;
}

.history-stat-card.warn {
  border-top: 3px solid #f59e0b;
}

.history-stat-card.info {
  border-top: 3px solid #2563eb;
}

.history-stat-card.total {
  border-top: 3px solid var(--primary-maroon);
}

.payroll-history-grid {
  display: grid;
  gap: 0.85rem;
  grid-template-columns: minmax(300px, 390px) minmax(0, 1fr);
  align-items: start;
}

.payroll-history-grid > * {
  min-width: 0;
}

.payroll-cycle-panel,
.payroll-detail-panel {
  border: 1px solid var(--border-color);
  border-radius: 14px;
  background: var(--card-bg);
  padding: 0.75rem;
  display: grid;
  gap: 0.65rem;
}

.payroll-detail-panel {
  min-width: 0;
  overflow: hidden;
}

#cycleDetailsContent {
  display: grid;
  gap: 0.7rem;
  min-width: 0;
}

#cycleDetailsContent.hidden {
  display: none !important;
}

.panel-heading {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 0.5rem;
  border-bottom: 1px solid var(--border-color);
  padding-bottom: 0.5rem;
}

.panel-heading h2 {
  margin: 0;
  font-size: 1.02rem;
  color: var(--heading-color);
}

.panel-heading span,
#detailPageLabel,
#cyclePageLabel {
  font-size: 0.76rem;
  color: var(--muted-color);
}

.cycle-list {
  max-height: 68vh;
  overflow: auto;
  display: grid;
  gap: 0.55rem;
  padding-right: 0.2rem;
}

.cycle-item {
  border: 1px solid var(--border-color);
  border-radius: 12px;
  padding: 0.62rem;
  background: color-mix(in srgb, var(--card-bg) 92%, var(--menu-bg-dark) 8%);
  cursor: pointer;
  transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
}

.cycle-tools {
  display: flex;
  align-items: center;
  gap: 0.34rem;
  justify-content: flex-end;
}

.cycle-replace-btn,
.cycle-delete-btn {
  border-radius: 8px;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.22rem 0.48rem;
  cursor: pointer;
  transition: background 0.2s ease, border-color 0.2s ease, transform 0.18s ease;
}

.cycle-replace-btn {
  border: 1px solid color-mix(in srgb, var(--primary-blue) 38%, var(--border-color) 62%);
  background: color-mix(in srgb, var(--primary-blue) 12%, var(--card-bg) 88%);
  color: var(--heading-color);
}

.cycle-replace-btn:hover {
  background: color-mix(in srgb, var(--primary-blue) 20%, var(--card-bg) 80%);
  border-color: color-mix(in srgb, var(--primary-blue) 60%, var(--border-color) 40%);
  transform: translateY(-1px);
}

.cycle-delete-btn {
  border: 1px solid color-mix(in srgb, var(--error-color) 45%, var(--border-color) 55%);
  background: color-mix(in srgb, var(--error-color) 12%, var(--card-bg) 88%);
  color: var(--heading-color);
}

.cycle-delete-btn:hover {
  background: color-mix(in srgb, var(--error-color) 22%, var(--card-bg) 78%);
  border-color: color-mix(in srgb, var(--error-color) 64%, var(--border-color) 36%);
  transform: translateY(-1px);
}

.cycle-item:hover {
  border-color: color-mix(in srgb, var(--accent-color) 65%, var(--border-color) 35%);
  box-shadow: 0 6px 16px color-mix(in srgb, var(--primary-blue) 12%, transparent 88%);
  transform: translateY(-1px);
}

.cycle-item.active {
  border-color: color-mix(in srgb, var(--primary-blue) 60%, var(--border-color) 40%);
  box-shadow: 0 8px 18px color-mix(in srgb, var(--primary-blue) 16%, transparent 84%);
}

.cycle-item .row-top {
  display: flex;
  justify-content: space-between;
  gap: 0.5rem;
  align-items: baseline;
}

.cycle-item .cycle-title {
  font-size: 0.87rem;
  color: var(--heading-color);
  font-weight: 700;
}

.cycle-item .cycle-date {
  font-size: 0.73rem;
  color: var(--muted-color);
}

.cycle-item .meta,
.cycle-item .stats {
  margin-top: 0.32rem;
  font-size: 0.76rem;
  color: var(--text-color);
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
}

.state-message {
  font-size: 0.86rem;
  color: var(--muted-color);
  padding: 0.65rem;
  border: 1px dashed var(--border-color);
  border-radius: 10px;
  background: color-mix(in srgb, var(--card-bg) 96%, var(--menu-bg-dark) 4%);
}

.panel-pagination {
  display: flex;
  gap: 0.45rem;
  align-items: center;
  justify-content: flex-end;
}

.panel-pagination .btn-action {
  height: 1.9rem;
  font-size: 0.77rem;
  padding: 0.3rem 0.72rem;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 0.75rem;
  border: 1px solid var(--border-color);
  border-radius: 11px;
  padding: 0.65rem 0.72rem;
  background: linear-gradient(160deg, color-mix(in srgb, var(--card-bg) 89%, var(--menu-bg-dark) 11%) 0%, color-mix(in srgb, var(--card-bg) 96%, var(--menu-bg-dark) 4%) 100%);
  min-width: 0;
  overflow: hidden;
}

.detail-header h2 {
  margin: 0;
  font-size: 1.05rem;
  color: var(--heading-color);
  line-height: 1.25;
  word-break: break-word;
}

.detail-header p {
  margin: 0.2rem 0 0;
  font-size: 0.78rem;
  color: var(--muted-color);
  line-height: 1.35;
  word-break: break-word;
}

.detail-header > div:first-child {
  min-width: 0;
}

.detail-header-actions {
  display: inline-flex;
  flex-wrap: nowrap;
  justify-content: flex-end;
  align-items: center;
  gap: 0.42rem;
}

.btn-history-source {
  background: linear-gradient(135deg, #0f5cb8 0%, #6f163b 100%);
  border-color: color-mix(in srgb, #0f5cb8 45%, #ffffff 55%);
  color: #ffffff;
  font-size: 0.85rem;
  letter-spacing: 0.01em;
  box-shadow: 0 8px 18px color-mix(in srgb, #0f5cb8 30%, transparent 70%);
}

.btn-history-source:hover {
  border-color: color-mix(in srgb, #0f5cb8 70%, #ffffff 30%);
  background: linear-gradient(135deg, #104a8f 0%, #58132f 100%);
}

.btn-history-register {
  text-decoration: none;
  background: linear-gradient(135deg, #0f766e 0%, #1d4ed8 100%);
  font-size: 0.78rem;
}

.btn-history-export {
  background: linear-gradient(135deg, #0f766e 0%, #14532d 100%);
  border-color: color-mix(in srgb, #0f766e 48%, #ffffff 52%);
  color: #ffffff;
}

.btn-history-export:hover {
  border-color: color-mix(in srgb, #0f766e 70%, #ffffff 30%);
  background: linear-gradient(135deg, #0a635b 0%, #124828 100%);
}

.btn-history-edit {
  background: linear-gradient(135deg, #1d4ed8 0%, #0f766e 100%);
  border-color: color-mix(in srgb, #1d4ed8 48%, #ffffff 52%);
  color: #ffffff;
}

.btn-history-edit:hover {
  border-color: color-mix(in srgb, #1d4ed8 68%, #ffffff 32%);
  background: linear-gradient(135deg, #1b44b8 0%, #0e655d 100%);
}

.detail-summary {
  display: grid;
  gap: 0.55rem;
  grid-template-columns: repeat(auto-fit, minmax(165px, 1fr));
}

.detail-stat {
  border: 1px solid var(--border-color);
  border-radius: 10px;
  padding: 0.55rem 0.62rem;
  background: color-mix(in srgb, var(--card-bg) 94%, var(--menu-bg-dark) 6%);
}

.detail-stat .label {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  color: var(--muted-color);
  font-weight: 700;
}

.detail-stat .value {
  margin-top: 0.14rem;
  font-size: 1rem;
  color: var(--heading-color);
  font-weight: 800;
}

.detail-filters {
  display: grid;
  grid-template-columns: minmax(260px, 1fr) minmax(200px, 1fr) auto;
  gap: 0.6rem;
  align-items: center;
}

.status-tabs {
  display: inline-flex;
  border: 1px solid var(--border-color);
  border-radius: 9px;
  overflow: hidden;
}

.status-tab {
  border: 0;
  background: transparent;
  color: var(--text-color);
  font-size: 0.8rem;
  font-weight: 700;
  padding: 0.42rem 0.7rem;
  cursor: pointer;
}

.status-tab.active {
  background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-maroon) 100%);
  color: #fff;
}

.detail-filters input {
  border: 1px solid var(--border-color);
  border-radius: 8px;
  background: var(--input-bg);
  color: var(--input-text);
  padding: 0.45rem 0.55rem;
  font-size: 0.84rem;
}

.detail-filters .btn-action {
  height: 1.95rem;
  font-size: 0.78rem;
  padding: 0.3rem 0.78rem;
}

.detail-table-wrap {
  border: 1px solid var(--border-color);
  border-radius: 10px;
  overflow: auto;
  max-width: 100%;
}

.detail-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 940px;
}

.detail-table thead th {
  position: sticky;
  top: 0;
  background: color-mix(in srgb, var(--menu-bg-dark) 86%, var(--card-bg) 14%);
  color: var(--heading-color);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  text-align: left;
  padding: 0.58rem 0.62rem;
  border-bottom: 1px solid var(--border-color);
}

.detail-table tbody td {
  padding: 0.55rem 0.62rem;
  font-size: 0.82rem;
  border-bottom: 1px solid var(--border-color);
  color: var(--text-color);
}

.detail-table tbody tr:hover {
  background: color-mix(in srgb, var(--card-bg) 86%, var(--accent-color) 14%);
}

.status-pill {
  display: inline-flex;
  border-radius: 999px;
  padding: 0.16rem 0.5rem;
  border: 1px solid transparent;
  font-size: 0.7rem;
  font-weight: 700;
}

.status-pill.matched {
  color: #166534;
  background: #dcfce7;
  border-color: #bbf7d0;
}

.status-pill.unmatched {
  color: #92400e;
  background: #fef3c7;
  border-color: #fde68a;
}

.payroll-modal {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3001;
  background: rgba(7, 13, 23, 0.54);
  backdrop-filter: blur(3px);
  -webkit-backdrop-filter: blur(3px);
  padding: 1rem;
}

.payroll-modal-panel {
  width: min(560px, 100%);
  max-height: 90vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  border: 1px solid color-mix(in srgb, var(--border-color) 88%, #ffffff 12%);
  border-radius: 14px;
  background: linear-gradient(160deg, color-mix(in srgb, var(--card-bg) 94%, var(--menu-bg-dark) 6%) 0%, color-mix(in srgb, var(--card-bg) 98%, var(--menu-bg-dark) 2%) 100%);
  box-shadow: 0 20px 45px color-mix(in srgb, #0f172a 38%, transparent 62%);
}

.payroll-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.65rem;
  padding: 0.8rem 0.95rem;
  border-bottom: 1px solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 3;
  background: color-mix(in srgb, var(--card-bg) 95%, var(--menu-bg-dark) 5%);
}

.payroll-modal-header h3 {
  margin: 0;
  color: var(--heading-color);
  font-size: 1rem;
}

.payroll-modal-close {
  border: 1px solid var(--border-color);
  background: color-mix(in srgb, var(--card-bg) 88%, var(--menu-bg-dark) 12%);
  color: var(--heading-color);
  width: 2rem;
  height: 2rem;
  border-radius: 8px;
  cursor: pointer;
  font-size: 1.2rem;
  line-height: 1;
}

.payroll-modal-close:hover {
  background: color-mix(in srgb, var(--primary-blue) 14%, var(--card-bg) 86%);
}

.payroll-modal-body {
  padding: 0.88rem 0.95rem 1rem;
  display: grid;
  gap: 0.72rem;
  flex: 1 1 auto;
  min-height: 0;
  overflow-y: auto;
}

.replace-cycle-note {
  margin: 0;
  color: var(--muted-color);
  font-size: 0.83rem;
  line-height: 1.45;
}

.replace-cycle-context {
  border: 1px solid var(--border-color);
  border-radius: 10px;
  background: color-mix(in srgb, var(--card-bg) 91%, var(--menu-bg-dark) 9%);
  padding: 0.62rem 0.7rem;
  display: grid;
  gap: 0.2rem;
  color: var(--text-color);
  font-size: 0.8rem;
}

.replace-cycle-form {
  display: grid;
  gap: 0.45rem;
}

.replace-cycle-form label {
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--heading-color);
}

.replace-cycle-form label span {
  color: var(--muted-color);
  font-weight: 600;
}

.replace-cycle-form input[type="file"] {
  border: 1px solid var(--border-color);
  border-radius: 8px;
  background: var(--input-bg);
  color: var(--input-text);
  padding: 0.45rem 0.52rem;
  font-size: 0.82rem;
}

.replace-cycle-form input[type="number"],
.replace-cycle-form select {
  border: 1px solid var(--border-color);
  border-radius: 8px;
  background: var(--input-bg);
  color: var(--input-text);
  padding: 0.45rem 0.52rem;
  font-size: 0.82rem;
}

.replace-cycle-actions {
  margin-top: 0.35rem;
  display: flex;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 0.42rem;
  position: sticky;
  bottom: 0;
  z-index: 3;
  padding: 0.6rem 0 0.1rem;
  border-top: 1px solid var(--border-color);
  background: color-mix(in srgb, var(--card-bg) 95%, var(--menu-bg-dark) 5%);
}

.btn-neutral {
  background: color-mix(in srgb, var(--card-bg) 82%, #6b7280 18%);
}

.btn-replace {
  background: linear-gradient(135deg, #0f5cb8 0%, #1d7c8b 100%);
  border-color: color-mix(in srgb, #0f5cb8 45%, #ffffff 55%);
  color: #ffffff;
}

.btn-replace:hover {
  background: linear-gradient(135deg, #0b4b95 0%, #166c79 100%);
}

@media (max-width: 1180px) {
  .payroll-history-grid {
    grid-template-columns: 1fr;
  }

  .cycle-list {
    max-height: 300px;
  }
}

@media (max-width: 920px) {
  .payroll-history-main {
    padding-left: 0.55rem;
    padding-right: 0.55rem;
  }

  .payroll-history-header {
    flex-direction: column;
  }

  .payroll-history-filters {
    grid-template-columns: 1fr 1fr;
  }

  .payroll-history-filters label {
    margin-top: 0.1rem;
  }

  .payroll-history-filters .btn-action {
    grid-column: 1 / -1;
    width: 100%;
  }

  .detail-filters {
    grid-template-columns: 1fr;
  }

  .detail-header {
    flex-direction: column;
    align-items: stretch;
  }

  .detail-header-actions {
    flex-wrap: wrap;
    justify-content: flex-start;
  }
}

@media (max-width: 640px) {
  .payroll-history-summary {
    grid-template-columns: 1fr 1fr;
  }

  .panel-pagination {
    justify-content: space-between;
  }

  .replace-cycle-actions {
    flex-direction: column-reverse;
  }

  .replace-cycle-actions .btn-action {
    width: 100%;
  }
}
