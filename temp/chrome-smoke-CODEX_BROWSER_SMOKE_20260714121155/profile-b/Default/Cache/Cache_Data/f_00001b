}

.live-chat-launcher {
    display: none;
    align-items: center;
    gap: 0.5rem;
    border: none;
    border-radius: 999px;
    background: var(--primary-maroon);
    color: #fff;
    padding: 0.7rem 1rem;
    box-shadow: var(--card-shadow-strong);
    cursor: pointer;
}

.live-chat-launcher strong {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    border-radius: 999px;
    background: var(--primary-gold);
    color: var(--primary-blue);
    font-size: 0.75rem;
}

.live-chat-dock.collapsed .live-chat-launcher {
    display: inline-flex;
}

.live-chat-dock.collapsed .live-chat-panel {
    display: none;
}

.live-chat-panel {
    width: min(780px, calc(100vw - 24px));
    height: min(620px, calc(100vh - 110px));
    background: var(--card-bg);
    border: 1px solid var(--table-border);
    border-radius: 10px;
    box-shadow: var(--card-shadow-strong);
    overflow: hidden;
    display: flex;
    flex-direction: column;
}

.live-chat-head,
.live-chat-peer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.9rem;
    border-bottom: 1px solid var(--table-border);
}

.live-chat-head {
    background: var(--primary-blue);
    color: #fff;
}

.live-chat-head small,
.live-chat-peer small {
    display: block;
    opacity: 0.85;
    font-size: 0.75rem;
}

.live-chat-head button {
    border: none;
    background: rgba(255,255,255,0.15);
    color: #fff;
    border-radius: 6px;
    padding: 0.35rem 0.55rem;
    cursor: pointer;
}

.live-chat-body {
    display: grid;
    grid-template-columns: 240px 1fr;
    min-height: 0;
    flex: 1;
}

.live-chat-users {
    border-right: 1px solid var(--table-border);
    overflow-y: auto;
    background: var(--surface-soft);
}

.live-chat-user {
    width: 100%;
    display: grid;
    grid-template-columns: 10px 34px 1fr;
    align-items: center;
    gap: 0.55rem;
    border: none;
    background: transparent;
    color: var(--text-color);
    padding: 0.65rem;
    text-align: left;
    cursor: pointer;
}

.live-chat-user.active,
.live-chat-user:hover {
    background: color-mix(in srgb, var(--primary-maroon) 9%, var(--card-bg) 91%);
}

.live-chat-user img {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
}

.live-chat-user strong,
.live-chat-user small {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.presence-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--muted-color);
}

.presence-dot.online {
    background: var(--success-color);
    box-shadow: 0 0 0 3px rgba(40,167,69,0.15);
}

.live-chat-thread {
    min-width: 0;
    min-height: 0;
    display: flex;
    flex-direction: column;
}

.live-chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 0.9rem;
    background: var(--bg-color);
}

.live-chat-empty {
    color: var(--muted-color);
    padding: 1rem;
    text-align: center;
}

.live-chat-bubble {
    max-width: 78%;
    margin: 0 0 0.65rem;
    background: var(--card-bg);
    border: 1px solid var(--table-border);
    border-radius: 10px;
    padding: 0.55rem 0.7rem;
}

.live-chat-bubble.own {
    margin-left: auto;
    background: color-mix(in srgb, var(--primary-blue) 12%, var(--card-bg) 88%);
}

.live-chat-bubble p {
    margin: 0 0 0.25rem;
    white-space: pre-wrap;
}

.live-chat-bubble small {
    display: block;
    color: var(--muted-color);
    font-size: 0.72rem;
    margin-top: 0.25rem;
}

.live-chat-bubble audio {
    width: 240px;
    max-width: 100%;
}

.live-chat-composer {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.55rem;
    padding: 0.65rem;
    border-top: 1px solid var(--table-border);
    background: var(--card-bg);
}

.live-chat-tools {
    display: flex;
    gap: 0.25rem;
}

.live-chat-tools button,
#liveSendBtn {
    border: 1px solid var(--table-border);
    border-radius: 6px;
    background: var(--surface-soft);
    color: var(--text-color);
    min-width: 34px;
    cursor: pointer;
}

.live-chat-tools button.recording {
    background: var(--error-color);
    color: #fff;
}

#liveChatInput {
    resize: none;
    border: 1px solid var(--table-border);
    border-radius: 6px;
    padding: 0.45rem 0.55rem;
    background: var(--input-bg);
    color: var(--input-text);
}

#liveSendBtn {
    background: var(--primary-maroon);
    color: #fff;
}

.emoji-picker {
    position: absolute;
    left: 0.65rem;
    bottom: 100%;
    display: grid;
    grid-template-columns: repeat(6, 32px);
    gap: 0.25rem;
    padding: 0.5rem;
    border: 1px solid var(--table-border);
    border-radius: 8px;
    background: var(--card-bg);
    box-shadow: var(--card-shadow);
}

.emoji-picker button {
    border: none;
    background: transparent;
    font-size: 1.1rem;
    cursor: pointer;
}

.live-call-modal {
    position: fixed;
    inset: 0;
    z-index: 4000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.65);
}

.live-call-card {
    width: min(760px, 94vw);
    background: #101820;
    color: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0,0,0,0.4);
}

.live-call-head,
.live-call-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    padding: 0.8rem 1rem;
}

.live-video-grid {
    display: grid;
    grid-template-columns: 1fr 190px;
    gap: 0.5rem;
    padding: 0 1rem 1rem;
}

.live-video-grid video {
    width: 100%;
    min-height: 220px;
    background: #000;
    border-radius: 8px;
    object-fit: cover;
}

.live-video-grid #liveLocalVideo {
    min-height: 120px;
}

.live-call-modal.audio-only .live-video-grid {
    display: none;
}

.live-call-actions button {
    border: none;
    border-radius: 8px;
    padding: 0.65rem 1rem;
    cursor: pointer;
}

#liveAcceptCallBtn {
    background: var(--success-color);
    color: #fff;
}

#liveRejectCallBtn,
#liveEndCallBtn {
    background: var(--error-color);
    color: #fff;
}

@media (max-width: 720px) {
    .live-chat-panel {
        width: calc(100vw - 16px);
        height: calc(100vh - 95px);
    }

    .live-chat-body {
        grid-template-columns: 120px 1fr;
    }

    .live-chat-user {
        grid-template-columns: 8px 1fr;
    }

    .live-chat-user img {
        display: none;
    }

    .live-chat-composer {
        grid-template-columns: 1fr auto;
    }

    .live-chat-tools {
        grid-column: 1 / -1;
    }
}

