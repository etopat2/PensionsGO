/* Comprehensive Modal System*/
.modal-system-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10010;
    padding: 1rem;
    backdrop-filter: blur(5px);
}

.modal-system {
    background: var(--card-bg);
    border-radius: 16px;
    width: 100%;
    max-width: 500px;
    overflow: hidden;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.4);
    border: 1px solid var(--border-color);
    animation: modalSlideIn 0.3s ease-out;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
}

/* Modal Header Variants */
.modal-header {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--form-bg);
    position: sticky;
    top: 0;
    z-index: 3;
}

.modal-header.error {
    border-top: 4px solid var(--urgent-color);
}

.modal-header.success {
    border-top: 4px solid var(--success-color);
}

.modal-header.warning {
    border-top: 4px solid var(--primary-gold);
}

.modal-header.info {
    border-top: 4px solid var(--primary-blue);
}

.modal-header.confirm {
    border-top: 4px solid var(--primary-maroon);
}

.modal-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
}

.modal-header.error .modal-icon {
    color: var(--urgent-color);
}

.modal-header.success .modal-icon {
    color: var(--success-color);
}

.modal-header.warning .modal-icon {
    color: var(--primary-gold);
}

.modal-header.info .modal-icon {
    color: var(--primary-blue);
}

.modal-header.confirm .modal-icon {
    color: var(--primary-maroon);
}

.modal-title {
    margin: 0;
    font-weight: 600;
    font-size: 1.3rem;
    color: var(--text-high-contrast);
}

.modal-header.error .modal-title {
    color: var(--urgent-color);
}

.modal-header.success .modal-title {
    color: var(--success-color);
}

.modal-header.warning .modal-title {
    color: var(--primary-gold);
}

.modal-header.info .modal-title {
    color: var(--primary-blue);
}

.modal-header.confirm .modal-title {
    color: var(--primary-maroon);
}

/* Modal Content */
.modal-content {
    padding: 2rem;
    text-align: center;
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
}

.modal-message {
    margin: 0 0 1.5rem 0;
    color: var(--text-color);
    font-size: 1rem;
    line-height: 1.6;
    text-align: left;
}

.modal-message.center {
    text-align: center;
}

/* Feedback Form Styles */
.feedback-form {
    text-align: left;
}

.feedback-group {
    margin-bottom: 1.5rem;
}

.feedback-group label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--text-high-contrast);
    font-weight: 600;
    font-size: 0.95rem;
}

.feedback-select,
.feedback-textarea {
    width: 100%;
    padding: 0.75rem;
    border: 2px solid var(--border-color);
    border-radius: 8px;
    background: var(--input-bg);
    color: var(--input-text);
    font-size: 0.95rem;
    font-family: inherit;
    transition: all 0.3s ease;
}

.feedback-select:focus,
.feedback-textarea:focus {
    outline: none;
    border-color: var(--primary-blue);
    box-shadow: 0 0 0 3px rgba(74, 134, 232, 0.15);
}

.feedback-textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.5;
}

.feedback-char-count {
    text-align: right;
    color: var(--muted-color);
    font-size: 0.8rem;
    margin-top: 0.25rem;
}

.feedback-char-count.warning {
    color: var(--primary-gold);
    font-weight: 600;
}

.feedback-char-count.error {
    color: var(--urgent-color);
    font-weight: 700;
}

/* Confirmation Details */
.confirmation-details {
    background: var(--form-bg);
    padding: 1rem;
    border-radius: 8px;
    margin: 1rem 0;
    border-left: 4px solid var(--primary-blue);
}

.confirmation-item {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
}

.confirmation-item:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
}

.confirmation-label {
    color: var(--muted-color);
    font-weight: 500;
}

.confirmation-value {
    color: var(--text-high-contrast);
    font-weight: 600;
}

/* Modal Actions */
.modal-actions {
    padding: 1.5rem 2rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    justify-content: center;
    gap: 1rem;
    background: var(--form-bg);
    position: sticky;
    bottom: 0;
    z-index: 3;
}

.modal-actions.single {
    justify-content: center;
}

.modal-actions.dual {
    justify-content: space-between;
}

.modal-btn {
    padding: 0.75rem 2rem;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.3s ease;
    min-width: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
}

.modal-btn-primary {
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-maroon) 100%);
    color: white;
    box-shadow: 0 2px 8px var(--shadow-light);
}

.modal-btn-primary:hover {
    background: linear-gradient(135deg, var(--primary-blue-dark) 0%, var(--primary-maroon-dark) 100%);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--shadow-medium);
}

.modal-btn-secondary {
    background: var(--card-bg);
    color: var(--text-color);
    border: 2px solid var(--border-color);
}

.modal-btn-secondary:hover {
    background: var(--message-hover);
    border-color: var(--primary-blue);
    transform: translateY(-2px);
}

.modal-btn-danger {
    background: linear-gradient(135deg, var(--urgent-color) 0%, var(--primary-maroon) 100%);
    color: white;
    box-shadow: 0 2px 8px rgba(220, 53, 69, 0.3);
}

.modal-btn-danger:hover {
    background: linear-gradient(135deg, #c82333 0%, var(--primary-maroon-dark) 100%);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(220, 53, 69, 0.4);
}

.modal-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none !important;
}

.modal-btn:disabled:hover {
    transform: none !important;
}

/* Loading State */
.modal-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2rem;
}

.modal-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--border-color);
    border-top: 3px solid var(--primary-blue);
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.modal-loading-text {
    color: var(--muted-color);
    font-size: 0.95rem;
}

/* Responsive Design */
@media (max-width: 768px) {
    .modal-system {
        max-width: 90%;
        margin: 1rem;
    }
    
    .modal-header {
        padding: 1.25rem 1.5rem;
    }
    
    .modal-content {
        padding: 1.5rem;
    }
    
    .modal-actions {
        padding: 1.25rem 1.5rem;
        flex-direction: column;
        gap: 0.75rem;
    }
    
    .modal-btn {
        width: 100%;
        min-width: auto;
    }
    
    .modal-actions.dual {
        flex-direction: column;
    }
}

@media (max-width: 480px) {
    .modal-system {
        max-width: 95%;
        margin: 0.5rem;
    }
    
    .modal-header {
        padding: 1rem 1.25rem;
    }
    
    .modal-content {
        padding: 1.25rem;
    }
    
    .modal-actions {
        padding: 1rem 1.25rem;
    }
}

/* Reduced motion support */
@media (prefers-reduced-motion: reduce) {
    .modal-system {
        animation: none;
    }
    
    .modal-btn:hover {
        transform: none;
    }
    
    .modal-spinner {
        animation: none;
        border-top-color: transparent;
    }
}

