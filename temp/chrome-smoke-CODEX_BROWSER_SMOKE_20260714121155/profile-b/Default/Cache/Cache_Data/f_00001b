/* MESSAGES MODULE STYLES - PROFESSIONAL COLOR HARMONY
   Uganda Prisons Service Color Scheme - Dark Mode Blues Enhanced
   ========================================================== */

@import url('color-variables.css');

/* Dark Modue Blue Enhancements*/
[data-theme="dark"] {
    /* Enhanced blue visibility for dark mode */
    --primary-blue: #4a86e8; /* Brighter, more saturated blue */
    --primary-blue-dark: #3a76d8; /* Slightly darker but still visible */
    --primary-blue-light: #6ba6ff; /* Light blue for highlights */
    
    --secondary-color: #4a86e8;
    --secondary-light: #6ba6ff;
    --secondary-dark: #3a76d8;
    
    /* Enhanced blue-based backgrounds */
    --unread-bg: rgba(74, 134, 232, 0.15); /* More visible blue tint */
    --message-hover: rgba(139, 0, 0, 0.1); /* Subtle maroon tint */
    
    /* Better contrast for blue text */
    --text-high-contrast: #ffffff;
    --border-enhanced: #4a86e8;
}

/* Base Styles With Color Harmony*/
:root {
    /* Message-specific color variants */
    --message-bg: var(--card-bg);
    --message-border: var(--border-color);
    --message-hover: rgba(139, 0, 0, 0.05); /* Subtle maroon tint */
    --unread-bg: rgba(0, 51, 102, 0.08); /* Subtle blue tint for unread */
    --urgent-color: var(--error-color);
    --success-color: var(--success-color);
    --broadcast-color: rgba(212, 175, 55, 0.9); /* Gold with opacity */
    --sidebar-bg: var(--card-bg);
    
    /* Enhanced contrast for elderly users */
    --text-high-contrast: var(--heading-color);
    --border-enhanced: var(--primary-blue-dark);
    --focus-glow: 0 0 0 3px rgba(212, 175, 55, 0.3);
}

/* Layout & Containers*/
.messages-container {
    display: flex;
    position: relative;
    top: 0;
    width: min(1480px, calc(100% - 2rem));
    height: calc(100dvh - var(--main-header-height, 70px) - var(--main-footer-height, 60px) - 1.9rem) !important;
    background: var(--bg-color);
    border-radius: 18px;
    overflow: hidden !important;
    box-shadow: 0 14px 32px var(--shadow-medium);
    margin: calc(var(--main-header-height, 70px) + 0.9rem) auto 1rem;
    border: 1px solid var(--border-color);
}

/* Sidebar Styles*/
.messages-sidebar {
    width: 280px;
    background: var(--sidebar-bg);
    border-right: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, var(--card-bg) 0%, var(--form-bg) 100%);
}

.sidebar-header {
    padding: 1.5rem;
    border-bottom: 1px solid var(--border-color);
    background: var(--card-bg);
}

.sidebar-header h2 {
    margin: 0 0 1rem 0;
    color: var(--primary-blue);
    font-size: 1.5rem;
    font-weight: 600;
}

.btn-compose {
    width: 100%;
    padding: 0.75rem 1rem;
    background: linear-gradient(135deg, var(--primary-maroon) 0%, var(--primary-blue) 100%);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px var(--shadow-light);
}

.btn-compose:hover {
    background: linear-gradient(135deg, var(--primary-maroon-dark) 0%, var(--primary-blue-dark) 100%);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--shadow-medium);
}

.btn-compose:active {
    transform: translateY(0);
}

/* Navigation*/
.sidebar-nav {
    flex: 1;
    padding: 1rem 0;
}

.nav-item {
    display: flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    color: var(--text-color);
    text-decoration: none;
    transition: all 0.3s ease;
    position: relative;
    border-left: 4px solid transparent;
    cursor: pointer;
    font-weight: 500;
    margin: 0.25rem 0.5rem;
    border-radius: 6px;
}

.nav-item:hover {
    background: var(--message-hover);
    border-left-color: var(--primary-gold);
    color: var(--primary-blue);
}

.nav-item.active {
    background: var(--unread-bg);
    border-left-color: var(--primary-blue);
    color: var(--primary-maroon);
    font-weight: 600;
    box-shadow: inset 0 0 0 1px var(--border-color);
}

.nav-item i {
    width: 20px;
    margin-right: 0.75rem;
    font-size: 0.9rem;
    color: var(--primary-blue);
}

.nav-item.active i {
    color: var(--primary-maroon);
}

.badge {
    background: var(--primary-maroon);
    color: white;
    border-radius: 12px;
    padding: 4px 8px;
    font-size: 0.7rem;
    font-weight: 700;
    margin-left: auto;
    display: none;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 20px;
    box-shadow: 0 2px 4px var(--shadow-light);
}

.badge:not(:empty) {
    display: flex;
}

/* Storage Info - Compact*/
.sidebar-footer {
    padding: 0.75rem 1.5rem;
    border-top: 1px solid var(--border-color);
    background: var(--form-bg);
}

.storage-info {
    margin-top: auto;
    padding: 0.5rem 0;
}

.storage-bar {
    height: 6px;
    background: var(--border-color);
    border-radius: 3px;
    margin: 0.5rem 0;
    overflow: hidden;
    position: relative;
}

.storage-progress {
    height: 100%;
    background: linear-gradient(90deg, var(--primary-blue) 0%, var(--primary-maroon) 100%);
    border-radius: 3px;
    transition: all 0.3s ease;
    width: 0%;
}

.storage-info small {
    color: var(--muted-color);
    font-size: 0.75rem;
    display: block;
    text-align: center;
    transition: all 0.3s ease;
    font-weight: 500;
}

/* Storage warning states */
.storage-info.warning small {
    color: var(--primary-gold-dark);
    font-weight: 600;
}

.storage-info.critical small {
    color: var(--urgent-color);
    font-weight: 700;
}

.storage-info.warning .storage-progress {
    background: var(--primary-gold);
}

.storage-info.critical .storage-progress {
    background: var(--urgent-color);
}

/* Main Content Area*/
.messages-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--message-bg);
    overflow: hidden !important;
}

/* List Header - Compact Layout*/
.list-header {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    background: var(--card-bg);
    gap: 1rem;
    min-height: 60px;
}

.list-header h3 {
    margin: 0;
    color: var(--primary-blue);
    font-size: 1.3rem;
    font-weight: 600;
    white-space: nowrap;
    line-height: 1.2;
    padding-top: 0.25rem;
}

.list-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: flex-end;
    flex: 1;
}

.batch-selection-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
}

.select-all-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.8rem;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--input-bg);
    color: var(--text-color);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
}

.select-all-toggle input {
    margin: 0;
}

.btn-batch-delete {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.65rem 0.95rem;
    border: 1px solid rgba(139, 0, 0, 0.22);
    border-radius: 8px;
    background: rgba(139, 0, 0, 0.08);
    color: var(--primary-maroon);
    font-size: 0.78rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.25s ease;
}

.btn-batch-delete:hover:not(:disabled),
.btn-batch-delete.active {
    background: rgba(139, 0, 0, 0.14);
    border-color: rgba(139, 0, 0, 0.35);
}

.btn-batch-delete:disabled {
    opacity: 0.45;
    cursor: not-allowed;
}

/* Search Box */
.search-box {
    position: relative;
    display: flex;
    align-items: center;
    flex: 1;
    max-width: 300px;
    min-width: 150px;
}

.search-box i {
    position: absolute;
    left: 0.75rem;
    color: var(--primary-blue);
    z-index: 2;
}

.search-box input {
    padding: 0.6rem 0.75rem 0.6rem 2.25rem;
    border: 2px solid var(--border-color);
    border-radius: 8px;
    background: var(--input-bg);
    color: var(--input-text);
    width: 100%;
    font-size: 0.7rem;
    transition: all 0.3s ease;
}

.search-box input:focus {
    outline: none;
    border-color: var(--primary-blue);
    box-shadow: var(--focus-glow);
}

/* Refresh Button */
.btn-refresh {
    padding: 0.5rem;
    border: 2px solid var(--border-color);
    background: var(--bg-color);
    color: var(--primary-blue);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    order: 1;
}

.btn-refresh:hover {
    background: var(--message-hover);
    border-color: var(--primary-blue);
    transform: rotate(180deg);
}

.btn-refresh:active {
    transform: rotate(180deg) scale(0.95);
}

/* Filter Dropdown */
.filter-dropdown {
    display: flex;
    align-items: center;
    order: 3;
}

.filter-dropdown select {
    padding: 0.6rem;
    border: 2px solid var(--border-color);
    background: var(--input-bg);
    color: var(--input-text);
    border-radius: 8px;
    min-width: 160px;
    height: 40px;
    font-size: 0.9rem;
    transition: all 0.3s ease;
}

.filter-dropdown select:focus {
    outline: none;
    border-color: var(--primary-blue);
    box-shadow: var(--focus-glow);
}

/* Messages List - Scroll Fixed*/
.messages-list {
    flex: 1;
    overflow-y: auto !important;
    max-height: calc(100vh - 240px) !important;
    background: var(--bg-color);
}

/* Message Items*/
.message-item {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border-color);
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--card-bg);
}

.message-item.selected {
    background: linear-gradient(135deg, rgba(109, 17, 22, 0.08) 0%, rgba(74, 134, 232, 0.05) 100%);
    box-shadow: inset 0 0 0 1px rgba(109, 17, 22, 0.2);
}

.message-item:hover {
    background: var(--message-hover);
    transform: translateX(4px);
}

.message-select {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 22px;
    height: 22px;
    margin-top: 0.25rem;
    cursor: pointer;
}

.message-select-checkbox {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    margin: 0;
}

.message-select-indicator {
    width: 18px;
    height: 18px;
    border-radius: 6px;
    border: 2px solid var(--border-color);
    background: var(--bg-color);
    transition: all 0.25s ease;
    position: relative;
}

.message-select-checkbox:checked + .message-select-indicator {
    background: var(--primary-maroon);
    border-color: var(--primary-maroon);
}

.message-select-checkbox:checked + .message-select-indicator::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 1px;
    width: 4px;
    height: 9px;
    border: solid #fff;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
}

/* Enhanced Unread Message Styling*/
.message-item.unread {
    background: linear-gradient(135deg, rgba(74, 134, 232, 0.08) 0%, rgba(139, 0, 0, 0.04) 100%);
    border-left: 4px solid var(--primary-blue);
    font-weight: 600;
    position: relative;
    border-right: 1px solid rgba(74, 134, 232, 0.1);
}

/* Dark mode specific unread background */
[data-theme="dark"] .message-item.unread {
    background: linear-gradient(135deg, rgba(74, 134, 232, 0.15) 0%, rgba(139, 0, 0, 0.08) 100%);
    border-right: 1px solid rgba(74, 134, 232, 0.2);
}

/* Unread indicator dot */
.message-item.unread::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 50%;
    transform: translateY(-50%);
    width: 8px;
    height: 8px;
    background: var(--primary-blue);
    border-radius: 50%;
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0% {
        box-shadow: 0 0 0 0 rgba(74, 134, 232, 0.7);
    }
    70% {
        box-shadow: 0 0 0 6px rgba(74, 134, 232, 0);
    }
    100% {
        box-shadow: 0 0 0 0 rgba(74, 134, 232, 0);
    }
}

/* Enhanced unread message content */
.message-item.unread .message-sender {
    color: var(--primary-blue);
    font-weight: 700;
}

.message-item.unread .message-subject {
    color: var(--primary-blue-dark);
    font-weight: 700;
}

[data-theme="dark"] .message-item.unread .message-subject {
    color: var(--primary-blue-light);
}

.message-item.unread .message-preview {
    color: var(--text-high-contrast);
    font-weight: 500;
}

/* Unread message metadata enhancement */
.message-item.unread .message-time {
    color: var(--primary-blue);
    font-weight: 600;
}

.message-item.unread .meta-attachment,
.message-item.unread .meta-recipients,
.message-item.unread .meta-broadcast {
    background: rgba(74, 134, 232, 0.1);
    color: var(--primary-blue);
    border: 1px solid rgba(74, 134, 232, 0.2);
}

/* Hover state for unread messages */
.message-item.unread:hover {
    background: linear-gradient(135deg, rgba(74, 134, 232, 0.12) 0%, rgba(139, 0, 0, 0.06) 100%);
    border-left: 4px solid var(--primary-blue-light);
    transform: translateX(4px);
}

[data-theme="dark"] .message-item.unread:hover {
    background: linear-gradient(135deg, rgba(74, 134, 232, 0.2) 0%, rgba(139, 0, 0, 0.1) 100%);
}

/* Urgent unread messages (combined states) */
.message-item.unread.urgent {
    background: linear-gradient(135deg, rgba(74, 134, 232, 0.08) 0%, rgba(220, 53, 69, 0.08) 100%);
    border-left: 4px solid var(--urgent-color);
}

.message-item.unread.urgent::before {
    background: var(--urgent-color);
    animation: pulseUrgent 1.5s infinite;
}

@keyframes pulseUrgent {
    0% {
        box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
    }
    70% {
        box-shadow: 0 0 0 6px rgba(220, 53, 69, 0);
    }
    100% {
        box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
    }
}

/* Broadcast unread messages */
.message-item.unread.broadcast {
    background: linear-gradient(135deg, rgba(74, 134, 232, 0.08) 0%, rgba(212, 175, 55, 0.08) 100%);
    border-left: 4px solid var(--broadcast-color);
}

.message-item.unread.broadcast::before {
    background: var(--broadcast-color);
    animation: pulseBroadcast 2s infinite;
}

@keyframes pulseBroadcast {
    0% {
        box-shadow: 0 0 0 0 rgba(212, 175, 55, 0.7);
    }
    70% {
        box-shadow: 0 0 0 6px rgba(212, 175, 55, 0);
    }
    100% {
        box-shadow: 0 0 0 0 rgba(212, 175, 55, 0);
    }
}

/* Enhanced avatar border for unread messages */
.message-item.unread .message-avatar {
    border: 2px solid var(--primary-blue);
    box-shadow: 0 0 0 1px rgba(74, 134, 232, 0.3);
}

/* Special treatment for sent folder unread states */
.message-item.unread .meta-recipients {
    background: rgba(139, 0, 0, 0.1);
    color: var(--primary-maroon);
    border: 1px solid rgba(139, 0, 0, 0.2);
}

/* Mobile adjustments for unread indicators */
@media (max-width: 768px) {
    .message-item.unread::before {
        left: 6px;
        width: 6px;
        height: 6px;
    }
    
    .message-item.unread {
        border-left: 3px solid var(--primary-blue);
    }
    
    .message-item.unread.urgent,
    .message-item.unread.broadcast {
        border-left-width: 3px;
    }
}

/* High contrast mode support for unread messages */
@media (prefers-contrast: high) {
    .message-item.unread {
        background: rgba(74, 134, 232, 0.2);
        border-left: 4px solid var(--primary-blue);
        border-right: 2px solid var(--primary-blue);
    }
    
    .message-item.unread::before {
        background: var(--primary-blue);
        width: 10px;
        height: 10px;
    }
}

/* Reduced motion support */
@media (prefers-reduced-motion: reduce) {
    .message-item.unread::before {
        animation: none;
        box-shadow: none;
    }
    
    .message-item.unread:hover {
        transform: none;
    }
}

/* Print styles for unread messages */
@media print {
    .message-item.unread {
        background: #f8f9fa !important;
        border-left: 3px solid #000 !important;
    }
    
    .message-item.unread::before {
        display: none;
    }
}

.message-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--border-color);
    background: var(--form-bg);
}

.message-content {
    flex: 1;
    min-width: 0;
}

.message-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.5rem;
}

.message-sender {
    font-weight: 600;
    color: var(--text-high-contrast);
    margin: 0;
    font-size: 0.95rem;
}

.message-time {
    color: var(--muted-color);
    font-size: 0.8rem;
    white-space: nowrap;
    font-weight: 500;
}

.message-subject {
    font-weight: 600;
    color: var(--primary-blue);
    margin: 0 0 0.5rem 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 1rem;
}

.message-preview {
    color: var(--muted-color);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 0.9rem;
    line-height: 1.4;
}

.message-meta {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
}

.meta-attachment,
.meta-recipients,
.meta-broadcast,
.meta-deleted {
    font-size: 0.75rem;
    color: var(--muted-color);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-weight: 500;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background: var(--form-bg);
}

.meta-broadcast {
    color: var(--primary-gold-dark);
    background: rgba(212, 175, 55, 0.1);
}

.meta-deleted {
    color: var(--urgent-color);
    background: rgba(220, 53, 69, 0.1);
}

.urgent-icon {
    color: var(--urgent-color);
    margin-right: 0.25rem;
}

/* Message Detail View*/
.message-detail-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    background: var(--card-bg);
}

.detail-header {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--card-bg);
}

.btn-back {
    background: var(--bg-color);
    border: 2px solid var(--border-color);
    padding: 0.6rem 1rem;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary-blue);
    transition: all 0.3s ease;
    font-weight: 500;
}

.btn-back:hover {
    background: var(--primary-blue);
    color: white;
    border-color: var(--primary-blue);
}

.detail-actions {
    display: flex;
    gap: 0.5rem;
}

.btn-action {
    padding: 0.6rem;
    border: 2px solid var(--border-color);
    background: var(--bg-color);
    color: var(--primary-blue);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    font-size: 1rem;
}

.btn-action:hover {
    background: var(--primary-blue);
    color: white;
    border-color: var(--primary-blue);
    transform: translateY(-2px);
}

.btn-action:active {
    transform: translateY(0);
}

.btn-action:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
}

.btn-action:disabled:hover {
    background: var(--bg-color);
    color: var(--primary-blue);
    border-color: var(--border-color);
}

.message-detail {
    flex: 1;
    padding: 1.5rem;
    overflow-y: auto !important;
    max-height: calc(100vh - 200px) !important;
    padding-bottom: 3rem;
}

/* Message Detail Content*/
.detail-header-info {
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
}

.detail-subject {
    margin: 0 0 1rem 0;
    color: var(--primary-blue);
    font-size: 1.5rem;
    font-weight: 600;
}

.detail-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
}

.sender-info {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.sender-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--primary-gold);
}

.sender-details {
    display: flex;
    flex-direction: column;
}

.sender-details strong {
    color: var(--text-high-contrast);
    margin-bottom: 0.25rem;
    font-size: 1.1rem;
}

.sender-details span {
    color: var(--muted-color);
    font-size: 0.9rem;
}

.detail-content {
    line-height: 1.7;
}

.message-text {
    white-space: pre-wrap;
    margin-bottom: 2rem;
    color: var(--text-color);
    font-size: 1rem;
    line-height: 1.8;
    background: var(--form-bg);
    padding: 1.5rem;
    border-radius: 8px;
    border-left: 4px solid var(--primary-blue);
}

.attachments-section {
    border-top: 1px solid var(--border-color);
    padding-top: 1.5rem;
    margin-top: 1rem;
}

.attachments-section h4 {
    margin: 0 0 1rem 0;
    color: var(--primary-blue);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
}

.attachments-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.attachment-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    border: 2px solid var(--border-color);
    border-radius: 8px;
    background: var(--form-bg);
    transition: all 0.3s ease;
}

.attachment-item:hover {
    border-color: var(--primary-blue);
    transform: translateX(4px);
}

.attachment-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-color);
    text-decoration: none;
    flex: 1;
}

.attachment-link:hover {
    color: var(--primary-blue);
}

.attachment-thumb {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 6px;
    border: 2px solid var(--border-color);
}

.attachment-item i {
    color: var(--primary-blue);
    font-size: 1.2rem;
}

/* Compose Modal*/
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3001;
    padding: 1rem;
    backdrop-filter: blur(5px);
    border: var(--border-color) 2px solid;
}

/* Broadcast Alert Modal*/
.broadcast-alert {
    background: var(--card-bg);
    border-radius: 16px;
    width: 100%;
    max-width: 460px;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.35);
    overflow: hidden;
    border: 1px solid var(--border-color);
    animation: modalSlideIn 0.3s ease-out;
}

.alert-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-maroon) 100%);
    color: #fff;
    border-bottom: 2px solid var(--primary-gold);
}

.alert-header i {
    font-size: 1.4rem;
}

.alert-header h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
}

.alert-content {
    padding: 1.5rem;
}

.alert-content h4 {
    margin: 0 0 0.5rem;
    color: var(--heading-color);
    font-size: 1.05rem;
    font-weight: 700;
}

.alert-content p {
    margin: 0 0 0.75rem;
    color: var(--text-color);
    line-height: 1.5;
}

.alert-sender {
    color: var(--muted-color);
    font-size: 0.85rem;
    font-weight: 600;
}

.alert-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    padding: 1rem 1.5rem 1.5rem;
    background: var(--menu-bg-dark);
    border-top: 1px solid var(--border-color);
}

@media (max-width: 576px) {
    .broadcast-alert {
        max-width: 92%;
    }

    .alert-actions {
        flex-direction: column;
    }

    .alert-actions .btn-primary,
    .alert-actions .btn-secondary {
        width: 100%;
    }
}

.compose-modal {
    background: var(--card-bg);
    border-radius: 16px;
    width: 100%;
    max-width: 750px;
    max-height: 90vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.4);
    border: 1px solid var(--border-color);
    animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
    from {
        opacity: 0;
        transform: translateY(-30px) scale(0.95);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

.compose-header {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-maroon) 100%);
    color: white;
    position: relative;
}

.compose-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--primary-gold) 0%, transparent 100%);
}

.compose-header h3 {
    margin: 0;
    color: white;
    font-weight: 600;
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.compose-header h3::before {
    content: '✉️';
    font-size: 1.2rem;
}

.btn-close {
    background: rgba(255, 255, 255, 0.15);
    border: none;
    font-size: 1.1rem;
    cursor: pointer;
    color: white;
    padding: 0.6rem;
    border-radius: 8px;
    transition: all 0.3s ease;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(10px);
}

.btn-close:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: rotate(90deg) scale(1.1);
}

/* Compose Form*/
.compose-form {
    flex: 1;
    overflow-y: auto;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.form-group {
    margin-bottom: 0;
}

.form-group label {
    display: block;
    margin-bottom: 0.75rem;
    color: var(--text-high-contrast);
    font-weight: 600;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.form-group label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border-color) 0%, transparent 100%);
    margin-left: 0.5rem;
}

/* Recipients Section */
.recipients-container {
    border: 2px solid var(--border-color);
    border-radius: 10px;
    background: var(--input-bg);
    transition: all 0.3s ease;
    overflow: hidden;
}

.recipients-container:focus-within {
    border-color: var(--primary-blue);
    box-shadow: 0 0 0 3px rgba(74, 134, 232, 0.15);
    transform: translateY(-1px);
}

.recipients-input-container {
    position: relative;
    padding: 0.5rem;
    border-bottom: 1px solid var(--border-color);
}

#recipientsSearch {
    width: 100%;
    padding: 0.72rem 0.78rem;
    border: none;
    background: transparent;
    color: var(--input-text);
    font-size: 0.95rem;
    border-radius: 6px;
    transition: all 0.3s ease;
}

#recipientsSearch:focus {
    outline: none;
    background: var(--form-bg);
}

#recipientsSearch::placeholder {
    color: var(--muted-color);
    font-style: italic;
}

.recipients-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--card-bg);
    border: 0.5px solid var(--primary-blue);
    border-radius: 10px;
    max-height: 500px;
    overflow-y: auto;
    z-index: 1000;
    box-shadow: 0 10px 30px var(--shadow-medium);
    margin-top: 0.5rem;
}

/* Custom scrollbar for dropdown */
.recipients-dropdown::-webkit-scrollbar {
    width: 6px;
}

.recipients-dropdown::-webkit-scrollbar-track {
    background: var(--form-bg);
    border-radius: 3px;
}

.recipients-dropdown::-webkit-scrollbar-thumb {
    background: var(--primary-blue);
    border-radius: 3px;
}

.recipients-dropdown::-webkit-scrollbar-thumb:hover {
    background: var(--primary-maroon);
}

.dropdown-item {
    padding: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    transition: all 0.3s ease;
    border-bottom: 1px solid var(--border-color);
}

.dropdown-item:last-child {
    border-bottom: none;
}

.dropdown-item:hover {
    background: var(--message-hover);
    transform: translateX(4px);
}

.dropdown-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--primary-gold);
    flex-shrink: 0;
}

.dropdown-user-info {
    flex: 1;
}

.dropdown-user-info strong {
    display: block;
    font-size: 0.9rem;
    color: var(--text-high-contrast);
    font-weight: 600;
}

.dropdown-user-info small {
    color: var(--muted-color);
    font-size: 0.8rem;
    display: block;
    margin-top: 0.1rem;
}

.selected-recipients {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 1rem;
    min-height: 3.5rem;
    background: var(--form-bg);
    align-items: center;
}

.recipient-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-maroon) 100%);
    color: white;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 500;
    box-shadow: 0 2px 8px var(--shadow-light);
    animation: chipAppear 0.3s ease-out;
}

@keyframes chipAppear {
    from {
        opacity: 0;
        transform: scale(0.8) translateY(10px);
    }
    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

.recipient-avatar {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    object-fit: cover;
    border: 1.5px solid rgba(255, 255, 255, 0.3);
}

.recipient-remove {
    background: rgba(255, 255, 255, 0.2);
    border: none;
    color: white;
    cursor: pointer;
    padding: 0;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 0.7rem;
    transition: all 0.3s ease;
}

.recipient-remove:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: scale(1.1);
}

/* Broadcast Section */
#broadcastSection {
    background: var(--form-bg);
    padding: 0.25rem;
    border-radius: 10px;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

#broadcastSection:hover {
    border-color: var(--primary-gold);
}

.checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    margin-bottom: 0;
    font-weight: 600;
    color: var(--text-high-contrast);
    font-size: 1rem;
}

.checkbox-label input[type="checkbox"] {
    display: none;
}

.checkmark {
    width: 20px;
    height: 20px;
    border: 2px solid var(--primary-blue);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    position: relative;
}

.checkmark::after {
    content: '✓';
    color: white;
    font-size: 0.8rem;
    font-weight: bold;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.checkbox-label input[type="checkbox"]:checked + .checkmark {
    background: var(--primary-blue);
    border-color: var(--primary-blue);
}

.checkbox-label input[type="checkbox"]:checked + .checkmark::after {
    opacity: 1;
}

.checkbox-label input[type="checkbox"]:disabled + .checkmark {
    opacity: 0.5;
    cursor: not-allowed;
}

.broadcast-options {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
    animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
    from {
        opacity: 0;
        max-height: 0;
    }
    to {
        opacity: 1;
        max-height: 200px;
    }
}

.broadcast-options label {
    margin-bottom: 0.75rem;
    color: var(--muted-color);
    font-weight: 500;
}

.role-checkboxes {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
}

.role-checkboxes .checkbox-label {
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--text-color);
}

.role-checkboxes .checkmark {
    width: 18px;
    height: 18px;
}

/* Enhanced Form Inputs */
.form-group input[type="text"],
.form-group textarea {
    width: 100%;
    padding: 1rem;
    border: 2px solid var(--border-color);
    border-radius: 10px;
    background: var(--input-bg);
    color: var(--input-text);
    font-size: 0.95rem;
    transition: all 0.3s ease;
    font-family: inherit;
}

.form-group input[type="text"]:focus,
.form-group textarea:focus {
    outline: none;
    border-color: var(--primary-blue);
    box-shadow: 0 0 0 3px rgba(74, 134, 232, 0.15);
    transform: translateY(-1px);
}

.form-group input[type="text"] {
    height: 50px;
}

.form-group textarea {
    resize: vertical;
    min-height: 150px;
    line-height: 1.6;
    padding: 1.25rem;
}

/* Enhanced File Upload */
.file-upload {
    position: relative;
    margin-bottom: 1rem;
}

.file-upload input[type="file"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
}

.file-upload-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1.5rem;
    background: var(--form-bg);
    border: 1px dashed var(--border-color);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s ease;
    color: var(--muted-color);
    font-weight: 500;
    width: 100%;
    justify-content: center;
}

.file-upload-label:hover {
    border-color: var(--primary-blue);
    color: var(--primary-blue);
    background: var(--unread-bg);
    transform: translateY(-2px);
}

.file-upload-label i {
    font-size: 1.1rem;
}

.selected-files {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.file-chip {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem;
    background: var(--form-bg);
    border: 2px solid var(--border-color);
    border-radius: 10px;
    transition: all 0.3s ease;
    animation: fileAppear 0.3s ease-out;
}

@keyframes fileAppear {
    from {
        opacity: 0;
        transform: translateX(-10px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

.file-chip:hover {
    border-color: var(--primary-blue);
    transform: translateX(4px);
}

.file-chip i {
    color: var(--primary-blue);
    font-size: 1.2rem;
    flex-shrink: 0;
}

.file-name-input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    background: var(--input-bg);
    color: var(--input-text);
    font-size: 0.85rem;
    transition: all 0.3s ease;
    min-width: 0;
}

.file-name-input:focus {
    outline: none;
    border-color: var(--primary-blue);
    box-shadow: 0 0 0 2px rgba(74, 134, 232, 0.1);
}

.file-chip small {
    color: var(--muted-color);
    font-size: 0.8rem;
    flex-shrink: 0;
}

.file-remove {
    background: var(--urgent-color);
    border: none;
    color: white;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 6px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    flex-shrink: 0;
}

.file-remove:hover {
    background: var(--primary-maroon);
    transform: scale(1.1);
}

/* Compose Actions */
.compose-actions {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    padding-top: 0.5rem 0.5rem;
    border-top: 1px solid var(--border-color);
    margin-top: auto;
    background: var(--card-bg);
    position: sticky;
    bottom: -25px;
}

.btn-secondary,
.btn-primary {
    padding: 1rem 2rem;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 120px;
    justify-content: center;
}

.btn-secondary {
    background: var(--form-bg);
    color: var(--text-color);
    border: 2px solid var(--border-color);
}

.btn-secondary:hover {
    background: var(--message-hover);
    border-color: var(--primary-blue);
    transform: translateY(-2px);
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-maroon) 100%);
    color: white;
    box-shadow: 0 4px 15px var(--shadow-medium);
}

.btn-primary:hover {
    background: linear-gradient(135deg, var(--primary-blue-dark) 0%, var(--primary-maroon-dark) 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px var(--shadow-dark);
}

.btn-primary:active {
    transform: translateY(0);
}

/* Responsive Design*/
@media (max-width: 768px) {
    .messages-container {
        display: flex;
        flex-direction: column;
        width: calc(100% - 0.5rem);
        height: calc(100dvh - var(--main-header-height, 70px) - var(--main-footer-height, 60px) - 0.75rem) !important;
        margin: calc(var(--main-header-height, 70px) + 0.35rem) auto 0.4rem;
        overflow: hidden !important;
        border-radius: 16px;
    }

    .messages-sidebar {
        width: 100%;
        border-right: none;
        border-bottom: 1px solid var(--border-color);
    }

    /* Mobile Sidebar Header - Title And Compose Button Side By Side*/
    .sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        gap: 1rem;
    }

    .sidebar-header h2 {
        margin: 0;
        font-size: 1.3rem;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .btn-compose {
        width: auto;
        min-width: 120px;
        padding: 0.6rem 1rem;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .sidebar-nav {
        display: flex;
        padding: 0;
        overflow-x: auto;
    }

    .nav-item {
        flex: 1;
        justify-content: center;
        border-left: none;
        border-bottom: 4px solid transparent;
        padding: 0.3rem 0.5rem;
        text-align: center;
        flex-direction: column;
        gap: 0.25rem;
        min-width: 100px;
        font-size: 0.8rem;
    }

    .nav-item.active {
        border-left: none;
        border-bottom-color: var(--primary-blue);
    }

    .nav-item i {
        margin-right: 0;
        font-size: 0.8rem;
    }

    .badge {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
    }

    /* Ensure list header stays fixed while content scrolls */
    .list-header {
        flex-shrink: 0;
        position: sticky;
        top: 0;
        background: var(--card-bg);
        z-index: 10;
        box-shadow: 0 2px 4px var(--shadow-light);
    }

    .batch-selection-controls {
        width: 100%;
        justify-content: space-between;
    }

    .select-all-toggle,
    .btn-batch-delete {
        flex: 1 1 180px;
        justify-content: center;
    }

    /* Ensure pagination stays at bottom */
    .list-footer {
        flex-shrink: 0;
        position: sticky;
        bottom: 0;
        background: var(--card-bg);
        z-index: 10;
        box-shadow: 0 -2px 4px var(--shadow-light);
    }

    .list-header h3 {
        align-self: flex-start;
        font-size: 1.1rem;
        padding-top: 0;
    }

    .list-actions {
        width: 100%;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .search-box {
        max-width: none;
        flex: 2;
        min-width: 120px;
    }

    .search-box input {
        width: 100%;
    }

    .filter-dropdown {
        flex: 1;
        min-width: 120px;
    }

    .filter-dropdown select {
        min-width: 100%;
        height: 36px;
    }

    .btn-refresh {
        width: 33px;
        height: 33px;
        flex-shrink: 0;
    }

    /* Compact storage info for mobile */
    .storage-info {
        padding: 0.15rem 0;
    }

    .storage-bar {
        height: 3px;
        margin: 0.5rem 0;
    }

    .storage-info small {
        font-size: 0.7rem;
        margin: 0.5rem 0;
    }

    /* Message detail view scrolling */
    .message-detail-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden !important;
        min-height: 0;
    }

    .message-detail {
        flex: 1;
        overflow-y: auto !important;
        max-height: none !important;
        -webkit-overflow-scrolling: touch !important;
        padding-bottom: 2rem;
        padding-bottom: 4rem; /* Ensure message detail has enough bottom space */
    }

    .messages-list,
    .message-detail {
        flex: 1;
        overflow-y: auto !important;
        max-height: none !important;
        -webkit-overflow-scrolling: touch !important;
        overflow-x: hidden !important;
        min-height: 0;
    }

    .messages-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden !important;
        min-height: 0; /* Crucial for flexbox scrolling */
    }

    .messages-list-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden !important;
        min-height: 0;
    }

    /* Fix for iOS Safari */
    @supports (-webkit-touch-callout: none) {
        .messages-list {
            height: 100% !important;
        }
        
        .message-detail {
            height: 100% !important;
        }
    }
}

@media (max-width: 480px) {
    .messages-container {
        width: calc(100% - 0.2rem);
