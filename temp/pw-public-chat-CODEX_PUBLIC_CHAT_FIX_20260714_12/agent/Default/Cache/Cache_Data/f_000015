    border-bottom: 1px solid var(--divider-color);
    color: var(--text-color);
}

.users-table th.table-checkbox,
.users-table td.table-checkbox {
    width: 48px;
    text-align: center;
    padding: 0.6rem;
}

.user-select-checkbox,
#selectAllUsers {
    width: 16px;
    height: 16px;
    accent-color: var(--primary-blue);
    cursor: pointer;
}

.users-table th {
    font-weight: 600;
    color: var(--heading-color);
}

.user-cell {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.user-avatar {
    width: 42px;
    height: 42px;
