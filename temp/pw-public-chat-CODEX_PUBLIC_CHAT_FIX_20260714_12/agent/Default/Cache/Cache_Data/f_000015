/* Export button loading state */
.action-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none !important;
}

.action-btn.is-sound-previewing {
    background: var(--primary-gold);
    border-color: color-mix(in srgb, var(--primary-gold) 76%, #000 24%);
    color: #1e2732;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary-gold) 28%, transparent 72%), 0 10px 22px rgba(0, 0, 0, 0.16);
}

.action-btn.is-sound-previewing::after {
    content: "";
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 999px;
    background: currentColor;
    margin-left: 0.45rem;
    animation: soundPreviewPulse 0.9s ease-in-out infinite;
}

.action-btn .loading-spinner {
    margin-right: 8px;
}

/* Export-specific notifications */
.admin-notification-success {
    background: var(--success-color);
    border-left: 4px solid #28a745;
}

.admin-notification-error {
    background: var(--error-color);
    border-left: 4px solid #dc3545;
}

.admin-notification-info {
    background: var(--info-color);
    border-left: 4px solid var(--primary-blue);
}

.admin-notification {
    position: fixed;
    right: 1.5rem;
    bottom: 1.5rem;
    z-index: var(--z-feedback-layer, 2147483647) !important;
    padding: 0.85rem 1rem;
    color: #fff;
    border-radius: 10px;
    box-shadow: 0 12px 25px rgba(0, 0, 0, 0.2);
    min-width: 240px;
    max-width: 320px;
    animation: slideFadeIn 0.2s ease;
}

.notification-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.notification-icon {
    font-size: 1.1rem;
}

.notification-message {
    font-size: 0.85rem;
    flex: 1;
}

.notification-close {
    background: transparent;
    border: none;
    color: #fff;
    font-size: 1rem;
    cursor: pointer;
}

@keyframes slideFadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes soundPreviewPulse {
    0%,
    100% {
        opacity: 0.45;
        transform: scale(0.86);
    }
    50% {
        opacity: 1;
        transform: scale(1);
    }
}

