/* ADMIN DASHBOARD STYLES
   Professional admin interface with enhanced security features
   ==================================================================== */

/* Admin Dashboard Layout */
.admin-dashboard {
    --admin-sidebar-width: clamp(260px, 18vw, 300px);
    --admin-content-max-width: 1600px;
    min-height: 100vh;
    background: var(--bg-color);
    display: flex;
    flex-direction: column;
}

[data-theme="dark"] .admin-modal-overlay,
[data-theme="dark"] .reauth-overlay {
    background: rgba(4, 8, 12, 0.74);
    backdrop-filter: blur(10px);
}

[data-theme="dark"] .admin-modal,
[data-theme="dark"] .admin-confirm-modal,
[data-theme="dark"] .security-modal,
[data-theme="dark"] .reauth-modal,
[data-theme="dark"] .notification-sound-modal,
[data-theme="dark"] .notification-sound-library-modal,
[data-theme="dark"] .notification-sound-confirm-modal,
[data-theme="dark"] .settings-card,
[data-theme="dark"] .settings-table-container,
[data-theme="dark"] .settings-toolbar,
[data-theme="dark"] .runtime-settings-card {
    border-color: rgba(143, 179, 207, 0.22);
    background: linear-gradient(180deg, rgba(27, 39, 50, 0.98), rgba(16, 24, 33, 0.98));
    color: var(--text-color);
    box-shadow: 0 24px 58px rgba(0, 0, 0, 0.46);
}

[data-theme="dark"] .admin-dashboard,
[data-theme="dark"] .admin-main,
[data-theme="dark"] .admin-content {
    background:
        radial-gradient(circle at top right, rgba(143, 179, 207, 0.08), transparent 30%),
        linear-gradient(180deg, #101822 0%, #0e141b 62%, #0a1017 100%);
    color: var(--text-color);
}

[data-theme="dark"] .admin-sidebar,
[data-theme="dark"] .admin-panel,
[data-theme="dark"] .admin-card,
[data-theme="dark"] .admin-section,
[data-theme="dark"] .management-card,
[data-theme="dark"] .chat-oversight-shell,
[data-theme="dark"] .chat-oversight-thread,
[data-theme="dark"] .chat-oversight-message {
    border-color: rgba(143, 179, 207, 0.2);
    background:
        linear-gradient(180deg, rgba(27, 39, 50, 0.94), rgba(18, 28, 38, 0.96));
    color: var(--text-color);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.32);
}

[data-theme="dark"] .chat-oversight-list,
[data-theme="dark"] .chat-oversight-thread-header,
[data-theme="dark"] .chat-oversight-messages,
[data-theme="dark"] .chat-oversight-toolbar,
[data-theme="dark"] .chat-oversight-summary {
    border-color: rgba(143, 179, 207, 0.18);
    background: rgba(15, 23, 32, 0.72);
}

[data-theme="dark"] .chat-oversight-item {
    border-bottom-color: rgba(143, 179, 207, 0.16);
    color: var(--text-color);
}

[data-theme="dark"] .chat-oversight-item:hover,
[data-theme="dark"] .chat-oversight-item.is-active {
    background: rgba(143, 179, 207, 0.13);
}

[data-theme="dark"] .chat-oversight-item.is-active {
    border-left-color: var(--primary-gold);
}

[data-theme="dark"] .chat-oversight-item-top em,
[data-theme="dark"] .chat-oversight-readonly,
[data-theme="dark"] .chat-oversight-kind,
[data-theme="dark"] .chat-oversight-badges span {
    border-color: rgba(143, 179, 207, 0.2);
    background: rgba(12, 20, 28, 0.78);
    color: var(--muted-dark);
}

[data-theme="dark"] .admin-modal-overlay,
[data-theme="dark"] .reauth-overlay {
    background: rgba(4, 8, 12, 0.74);
    backdrop-filter: blur(10px);
}

[data-theme="dark"] .admin-modal,
[data-theme="dark"] .admin-confirm-modal,
[data-theme="dark"] .security-modal,
[data-theme="dark"] .reauth-modal,
[data-theme="dark"] .notification-sound-modal,
[data-theme="dark"] .notification-sound-library-modal,
[data-theme="dark"] .notification-sound-confirm-modal {
    border: 1px solid rgba(143, 179, 207, 0.22);
    background:
        linear-gradient(180deg, rgba(27, 39, 50, 0.98), rgba(16, 24, 33, 0.98));
    color: var(--text-color);
    box-shadow: 0 30px 74px rgba(0, 0, 0, 0.56);
}

[data-theme="dark"] .admin-modal-header,
[data-theme="dark"] .content-header,
[data-theme="dark"] .settings-header {
    border-color: rgba(220, 178, 80, 0.24);
}

[data-theme="dark"] .settings-card,
[data-theme="dark"] .settings-table-container,
[data-theme="dark"] .settings-toolbar,
[data-theme="dark"] .runtime-settings-card {
    border-color: rgba(143, 179, 207, 0.2);
    background:
        linear-gradient(180deg, rgba(27, 39, 50, 0.94), rgba(18, 28, 38, 0.96));
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.32);
}

/* Chat Oversight */
.chat-oversight-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 0;
}

.chat-oversight-summary,
.chat-oversight-toolbar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.65rem;
}

.chat-oversight-toolbar .filter-input {
    flex: 1 1 280px;
}

.chat-oversight-shell {
    display: grid;
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
    min-height: 620px;
    height: calc(100vh - var(--main-header-height, 70px) - var(--main-footer-height, 40px) - 245px);
    border: 1px solid var(--border-color);
    background: var(--card-bg);
    overflow: hidden;
}

.chat-oversight-list {
    border-right: 1px solid var(--border-color);
    background: var(--surface-soft);
    overflow-y: auto;
}

.chat-oversight-item {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 0.45rem;
    padding: 0.9rem 1rem;
    border: 0;
    border-bottom: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-color);
    text-align: left;
    cursor: pointer;
}

.chat-oversight-item:hover,
.chat-oversight-item.is-active {
    background: var(--hover-bg);
}

.chat-oversight-item.is-active {
    border-left: 4px solid var(--primary-maroon);
}

.chat-oversight-item-top,
.chat-oversight-item-meta,
.chat-oversight-message-head,
.chat-oversight-message-foot,
.chat-oversight-thread-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
}

.chat-oversight-item-top strong,
.chat-oversight-thread-header h3 {
    color: var(--heading-color);
}

.chat-oversight-item-top em,
.chat-oversight-readonly,
.chat-oversight-kind,
.chat-oversight-badges span {
    border: 1px solid var(--border-color);
    background: var(--card-bg);
    color: var(--muted-color);
    font-size: 0.72rem;
    font-style: normal;
    font-weight: 700;
    padding: 0.18rem 0.45rem;
    text-transform: uppercase;
}

.chat-oversight-item-preview {
    color: var(--muted-color);
    font-size: 0.86rem;
    line-height: 1.35;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}

.chat-oversight-item-meta {
    color: var(--muted-color);
    font-size: 0.78rem;
}

.chat-oversight-thread {
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 0;
    background: var(--card-bg);
}

.chat-oversight-thread-header {
    position: sticky;
    top: 0;
    z-index: 5;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--border-color);
    background: var(--surface-soft);
}

.chat-oversight-thread-header h3,
.chat-oversight-thread-header p {
    margin: 0;
}

.chat-oversight-thread-header p {
    margin-top: 0.25rem;
    color: var(--muted-color);
    font-size: 0.86rem;
}

.chat-oversight-messages {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 1rem;
    background: color-mix(in srgb, var(--bg-color) 86%, var(--card-bg));
}

.chat-oversight-message {
    max-width: min(720px, 92%);
    margin: 0 0 0.9rem;
    padding: 0.85rem 0.95rem;
    border: 1px solid var(--border-color);
    background: var(--card-bg);
    box-shadow: 0 1px 2px var(--shadow-light);
}

.chat-oversight-message.is-deleted {
    background: var(--surface-soft);
}

.chat-oversight-message-head {
    color: var(--heading-color);
    font-size: 0.86rem;
}

.chat-oversight-message-head time,
.chat-oversight-message-foot {
    color: var(--muted-color);
    font-size: 0.76rem;
}

.chat-oversight-text {
    margin-top: 0.55rem;
    color: var(--text-color);
    line-height: 1.45;
    overflow-wrap: anywhere;
}

.chat-oversight-text.muted,
.chat-oversight-deleted {
    color: var(--muted-color);
    font-style: italic;
}

.chat-oversight-attachment,
.chat-oversight-reply {
    margin-top: 0.55rem;
    padding: 0.55rem 0.65rem;
    border-left: 3px solid var(--primary-gold);
    background: var(--surface-soft);
    color: var(--text-color);
}

.chat-oversight-reply {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    max-height: 4.8rem;
    overflow: hidden;
}

.chat-oversight-reply span {
    color: var(--muted-color);
}

.chat-oversight-call-record {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.6rem;
    padding: 0.7rem 0.75rem;
    border: 1px solid var(--border-color);
    border-left: 3px solid var(--primary-gold);
    background: var(--surface-soft);
    color: var(--text-color);
}

.chat-oversight-call-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.15rem;
    height: 2.15rem;
    border-radius: 50%;
    background: rgba(109, 17, 22, 0.12);
    color: var(--primary-color);
}

.chat-oversight-call-main {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.15rem;
}

.chat-oversight-call-main span,
.chat-oversight-call-main small,
.chat-oversight-call-meta {
    color: var(--muted-color);
}

.chat-oversight-call-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.15rem;
    font-size: 0.78rem;
    white-space: nowrap;
}

.chat-oversight-call-record.missed,
.chat-oversight-call-record.rejected,
.chat-oversight-call-record.failed {
    border-left-color: var(--danger-color);
}

.chat-oversight-message-foot {
    justify-content: flex-start;
    margin-top: 0.65rem;
    flex-wrap: wrap;
}

.chat-oversight-thread-actions {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.55rem;
    flex-wrap: wrap;
}

.chat-oversight-delete-btn {
    margin-left: auto;
    border: 1px solid color-mix(in srgb, var(--danger-color, #dc3545) 45%, var(--border-color) 55%);
    background: color-mix(in srgb, var(--danger-color, #dc3545) 10%, var(--card-bg) 90%);
    color: var(--danger-color, #dc3545);
    font-size: 0.74rem;
    font-weight: 800;
    padding: 0.22rem 0.5rem;
    cursor: pointer;
}

.chat-oversight-badges {
    display: inline-flex;
    gap: 0.35rem;
    flex-wrap: wrap;
}

.chat-oversight-reaction {
    margin-left: auto;
    font-size: 1rem;
}

.chat-oversight-date-divider {
    display: flex;
    justify-content: center;
    margin: 0.25rem 0 1rem;
}

.chat-oversight-date-divider span {
    padding: 0.3rem 0.7rem;
    background: var(--menu-bg);
    color: white;
    font-size: 0.78rem;
    font-weight: 700;
}

.chat-oversight-empty,
.chat-oversight-placeholder {
    padding: 1rem;
    color: var(--muted-color);
    text-align: center;
}

.chat-oversight-footer {
    display: flex;
    justify-content: center;
    padding: 0.75rem;
    border-top: 1px solid var(--border-color);
    background: var(--surface-soft);
}

@media (max-width: 900px) {
    .chat-oversight-shell {
        grid-template-columns: 1fr;
        height: auto;
        min-height: 0;
    }

    .chat-oversight-list {
        max-height: 310px;
        border-right: 0;
        border-bottom: 1px solid var(--border-color);
    }

    .chat-oversight-messages {
        min-height: 440px;
    }
}

/* Admin Header */
.admin-header {
    background: var(--header-bg);
    color: var(--header-text);
    padding: 0;
    box-shadow: 0 2px 10px var(--shadow-medium);
    border-bottom: 3px solid var(--header-border);
    position: sticky;
    top: 0;
    z-index: 1000;
    margin-left: var(--admin-sidebar-width);
    width: calc(100% - var(--admin-sidebar-width));
}

/* Admin Main Content - FIXED LAYOUT */
.admin-main {
    display: flex;
    flex: 1;
    min-height: calc(100vh - var(--main-header-height, 70px) - var(--main-footer-height, 40px));
    height: calc(100vh - var(--main-header-height, 70px) - var(--main-footer-height, 40px));
    min-width: 0;
    position: relative;
    top: var(--main-header-height, 70px);
    overflow: hidden;
}

/* Admin Sidebar - DESKTOP STYLES ONLY */
.admin-sidebar {
    width: var(--admin-sidebar-width);
    background: var(--menu-bg);
    border-right: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    box-shadow: 2px 0 10px var(--shadow-light);
    position: fixed;
    left: 0;
    top: var(--main-header-height, 70px);
    bottom: var(--main-footer-height, 40px);
    z-index: 1000;
    overflow-y: auto;
}

.sidebar-header {
    padding: 1.5rem;
    border-bottom: 1px solid var(--divider-color);
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-maroon) 100%);
    color: white;
}

.admin-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    width: 100%;
    justify-content: center;
}

.brand-icon {
    font-size: 1.5rem;
    background: rgba(255, 255, 255, 0.2);
    padding: 0.5rem;
    border-radius: 8px;
}

.admin-brand h2 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    text-align: center;
}

.admin-info {
    display: none;
    /* align-items: center;
    gap: 0.75rem; */
}

.admin-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--primary-gold);
}

.admin-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.admin-details {
    flex: 1;
}

.admin-name {
    display: block;
    font-weight: 600;
    font-size: 0.95rem;
    color: white;
}

.admin-role {
    display: block;
    font-size: 0.8rem;
    opacity: 0.9;
    background: var(--primary-gold);
    color: var(--primary-blue);
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    font-weight: 600;
    margin-top: 0.2rem;
}

/* Sidebar Navigation - DESKTOP */
.sidebar-nav {
    position: relative;
    flex: 1;
    padding: 0 0;
    overflow-y: auto;
    top: -25px;
    height: 100%;

}

.nav-menu {
    list-style: none;
    padding: 0;
    margin: 0;
}

.nav-item {
    margin-bottom: 0.25rem;
}

.nav-link {
    display: flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    color: var(--text-color);
    text-decoration: none;
    transition: all 0.3s ease;
    position: relative;
    border-left: 3px solid transparent;
}

.nav-link:hover {
    background: var(--menu-item-hover);
    color: white;
    border-left-color: var(--primary-gold);
}

.nav-link.active {
    background: var(--menu-item-active);
    color: white;
    border-left-color: var(--primary-gold);
    font-weight: 600;
}

.nav-icon {
    font-size: 1.1rem;
    margin-right: 0.75rem;
    width: 20px;
    text-align: center;
}

.nav-text {
    flex: 1;
    font-size: 0.9rem;
}

.nav-badge {
    background: var(--primary-gold);
    color: var(--primary-blue);
    padding: 0.2rem 0.5rem;
    border-radius: 10px;
    font-size: 0.75rem;
    font-weight: 700;
    min-width: 20px;
    text-align: center;
}

.nav-arrow {
    font-size: 0.8rem;
    transition: transform 0.3s ease;
}

.has-submenu.open .nav-arrow {
    transform: rotate(180deg);
}

/* Submenu - DESKTOP */
.submenu {
    list-style: none;
    padding: 0;
    margin: 0;
    background: var(--menu-bg-dark);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
}

.has-submenu.open .submenu {
    max-height: 900px;
    overflow-y: auto;
}

.submenu-link {
    display: block;
    padding: 0.6rem 1.5rem 0.6rem 3.5rem;
    color: var(--text-color);
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.3s ease;
    border-left: 2px solid transparent;
}

.submenu-link:hover {
    background: var(--hover-bg);
    color: white;
    border-left-color: var(--primary-gold-light);
}

.submenu-link.active {
    background: var(--primary-blue);
    color: white;
    border-left-color: var(--primary-gold);
    font-weight: 600;
}

.submenu-group {
    display: block;
}

.submenu-group-label {
    font-weight: 700;
}

.nested-submenu {
    list-style: none;
    margin: 0;
    padding: 0 0 0.25rem;
    background: rgba(0, 0, 0, 0.12);
}

.nested-submenu-link {
    padding-left: 4.4rem;
    font-size: 0.8rem;
    border-left-width: 3px;
}

.nested-submenu-link::before {
    content: "";
    display: inline-block;
    width: 0.35rem;
    height: 0.35rem;
    margin-right: 0.45rem;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.55;
    vertical-align: middle;
}

/* Sidebar Footer - DESKTOP */
.sidebar-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--divider-color);
    background: var(--menu-bg-dark);
}

.system-status {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.status-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
}

.status-label {
    color: var(--muted-color);
}

.status-value {
    color: var(--text-color);
    font-weight: 600;
}

.health-indicator {
    color: var(--success-color);
    font-weight: bold;
}

.health-indicator.warning {
    color: var(--warning-color);
}

.health-indicator.error {
    color: var(--error-color);
}

/* Admin Content Area - FIXED LAYOUT */
.admin-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--bg-color);
    margin-left: var(--admin-sidebar-width);
    min-height: 0;
    min-width: 0;
    width: calc(100vw - var(--admin-sidebar-width));
    max-width: calc(100vw - var(--admin-sidebar-width));
    overflow: hidden;
}

.content-header {
    padding: clamp(1rem, 2vw, 1.5rem) clamp(1rem, 2.4vw, 2rem);
    background: var(--card-bg);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 2px 4px var(--shadow-light);
    position: sticky;
    top: 0;
    z-index: 99;
}

.breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
}

.breadcrumb-item {
    color: var(--muted-color);
}

.breadcrumb-item.active {
    color: var(--primary-blue);
    font-weight: 600;
}

.breadcrumb-separator {
    color: var(--muted-dark);
}

.content-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.action-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--primary-blue);
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.3s ease;
}

.action-btn:hover {
    background: var(--primary-blue-dark);
    transform: translateY(-1px);
}

.action-icon {
    font-size: 0.9rem;
}

.admin-search {
    position: relative;
    min-width: min(320px, 100%);
    flex: 0 0 auto;
}

.search-input {
    padding: 0.5rem 2.5rem 0.5rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    background: var(--input-bg);
    color: var(--input-text);
    font-size: 0.85rem;
    width: min(360px, 100%);
}

.search-input:focus {
    outline: none;
    border-color: var(--primary-gold);
    box-shadow: 0 0 0 2px var(--shadow-light);
}

.search-icon {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted-color);
}

/* Content Body */
.content-body {
    flex: 1;
    min-height: 0;
    min-width: 0;
    width: 100%;
    max-width: 100%;
    padding: clamp(1rem, 2vw, 2rem);
    padding-bottom: calc(2rem + var(--main-footer-height, 0px) + env(safe-area-inset-bottom));
    padding-bottom: 3.5rem;
    overflow: auto;
    overscroll-behavior: contain;
    background: var(--bg-color);
}

.content-body > * {
    width: 100%;
    max-width: min(var(--admin-content-max-width), 100%);
    margin-left: auto;
    margin-right: auto;
}

/* Dashboard Styles */
.welcome-message {
    text-align: center;
    padding: 3rem 2rem;
    max-width: 100%;
    margin: 0 auto;
}

.welcome-icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
}

.welcome-message h1 {
    color: var(--heading-color);
    margin-bottom: 1rem;
    font-size: 2.5rem;
}

.welcome-message p {
    color: var(--muted-color);
    font-size: 1.1rem;
    margin-bottom: 2rem;
}

.welcome-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
}

.stat-card {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 8px;
    box-shadow: 0 2px 8px var(--shadow-light);
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: transform 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--shadow-medium);
}

.stat-icon {
    font-size: 2rem;
    background: var(--primary-blue);
    color: white;
    padding: 0.5rem;
    border-radius: 8px;
}

.stat-info {
    display: flex;
    flex-direction: column;
}

.stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--heading-color);
}

.stat-label {
    font-size: 0.85rem;
    color: var(--muted-color);
}

.dashboard-content {
    max-width: 1200px;
    width: 100%;
    padding: 0;
    margin: 0 auto;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.dashboard-widgets {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 1.5rem;
}

.widget {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 8px;
    box-shadow: 0 2px 8px var(--shadow-light);
}

/* User Management */
.user-management-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.section-title {
    margin: 0 0 0.35rem;
    font-size: 1.4rem;
    color: var(--heading-color);
    font-weight: 700;
}

.section-subtitle {
    margin: 0;
    color: var(--muted-color);
    font-size: 0.95rem;
}

/* App Settings */
.settings-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-bottom: 2.5rem;
    min-width: 0;
    max-width: 100%;
}

.settings-content > * {
    min-width: 0;
    max-width: 100%;
}

.settings-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
}

.settings-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
}

.settings-status {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--input-bg);
    border: 1px solid var(--divider-color);
    color: var(--muted-color);
}

.settings-status.status-success {
    background: rgba(40, 167, 69, 0.12);
    border-color: rgba(40, 167, 69, 0.4);
    color: #1f7a3b;
}

.settings-status.status-error {
    background: rgba(220, 53, 69, 0.12);
    border-color: rgba(220, 53, 69, 0.4);
    color: #b02a37;
}

.settings-status.status-info {
    background: rgba(0, 51, 102, 0.12);
    border-color: rgba(0, 51, 102, 0.35);
    color: var(--primary-blue);
}

.settings-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-left: 0.4rem;
    border: 1px solid var(--divider-color);
    color: var(--muted-color);
    background: rgba(0, 51, 102, 0.08);
}

.settings-pill.planned {
    border-color: rgba(212, 175, 55, 0.6);
    color: #7a5a14;
    background: rgba(212, 175, 55, 0.15);
}

.settings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.25rem;
}

.settings-card {
    background: var(--card-bg);
    border-radius: 14px;
    padding: 1.25rem;
    box-shadow: 0 2px 10px var(--shadow-light);
    border: 1px solid var(--divider-color);
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.settings-card-header h3 {
    margin: 0 0 0.35rem;
    color: var(--heading-color);
    font-size: 1.05rem;
}

.settings-card-header p {
    margin: 0;
    color: var(--muted-color);
    font-size: 0.9rem;
}

.settings-card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.85rem;
}

.settings-fields {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
}

.settings-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.88rem;
    color: var(--muted-color);
}

.settings-field span {
    color: var(--text-color);
    font-weight: 600;
}

.settings-field input,
.settings-field select,
.settings-field textarea {
    padding: 0.6rem 0.8rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--input-bg);
    color: var(--text-color);
    font-size: 0.9rem;
}

.settings-field textarea {
    resize: vertical;
}

.app-version-card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
}

.app-version-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
}

.app-version-summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.85rem;
}

.app-version-summary-card {
    border: 1px solid var(--divider-color);
    border-radius: 12px;
    background: var(--form-bg);
    padding: 0.85rem 0.9rem;
    display: grid;
    gap: 0.35rem;
}

.app-version-summary-label {
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted-color);
}

.app-version-summary-card strong {
    font-size: 0.96rem;
    color: var(--heading-color);
    word-break: break-word;
}

.app-version-summary-card small {
    color: var(--muted-dark);
    line-height: 1.45;
}

.form-checkbox {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-color);
}

.form-checkbox input {
    accent-color: var(--primary-blue);
}

.settings-toggle {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0.9rem;
    border-radius: 10px;
    border: 1px solid var(--divider-color);
    background: var(--input-bg);
}

.toggle-title {
    font-weight: 600;
    color: var(--heading-color);
}

.toggle-subtitle {
    font-size: 0.82rem;
    color: var(--muted-color);
}

.settings-toggle .switch {
    position: relative;
    display: inline-block;
    flex: 0 0 auto;
    width: 44px;
    min-width: 44px;
    height: 24px;
}

.settings-toggle .switch input {
    opacity: 0;
    width: 0;
    height: 0;
}

.settings-toggle .switch .slider {
    position: absolute;
    cursor: pointer;
    inset: 0;
    background-color: #c6cbd3;
    transition: 0.2s;
    border-radius: 20px;
}

.settings-toggle .switch .slider:before {
    position: absolute;
    content: "";
    height: 18px;
    width: 18px;
    left: 3px;
    bottom: 3px;
    background-color: #fff;
    transition: 0.2s;
    border-radius: 50%;
}

.settings-toggle .switch input:checked + .slider {
    background-color: var(--primary-blue);
}

.settings-toggle .switch input:checked + .slider:before {
    transform: translateX(20px);
}

.settings-toggle .switch input:focus + .slider {
    box-shadow: 0 0 0 2px rgba(0, 51, 102, 0.2);
}

.settings-note {
    background: rgba(0, 51, 102, 0.08);
    border: 1px solid var(--divider-color);
    padding: 0.75rem 1rem;
    border-radius: 10px;
    color: var(--text-color);
    font-size: 0.9rem;
}

.notification-permission-note {
    display: grid;
    gap: 0.35rem;
}

.notification-sound-range {
    display: flex;
    align-items: center;
    gap: 0.85rem;
}

.notification-sound-range input[type="range"] {
    flex: 1 1 auto;
    padding: 0;
}

.notification-sound-range output {
    min-width: 3.5rem;
    font-weight: 700;
    color: var(--heading-color);
    text-align: right;
}

.notification-sound-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
}

.notification-sound-manager {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.95rem;
    border: 1px solid color-mix(in srgb, var(--border-color) 74%, var(--primary-blue) 26%);
    border-radius: 12px;
    background: color-mix(in srgb, var(--card-bg) 86%, var(--primary-blue) 14%);
}

.notification-sound-manager > div:first-child {
    display: grid;
    gap: 0.18rem;
    min-width: 0;
}

.notification-sound-manager strong {
    color: var(--heading-color);
}

.notification-sound-modal {
    width: min(720px, 94vw);
}

.notification-sound-library-modal {
    width: min(920px, 95vw);
}

.notification-sound-dropzone {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 0.42rem;
    padding: 1.3rem;
    border: 1px dashed color-mix(in srgb, var(--primary-blue) 46%, var(--border-color) 54%);
    border-radius: 14px;
    background: color-mix(in srgb, var(--card-bg) 86%, var(--primary-gold) 14%);
    color: var(--text-color);
    text-align: center;
    cursor: pointer;
}

.notification-sound-dropzone input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
}

.notification-sound-dropzone-icon {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: var(--primary-maroon);
    color: #fff;
    font-size: 1.4rem;
    font-weight: 800;
}

.notification-sound-upload-note {
    margin-top: 0.9rem;
}

.notification-sound-library-toolbar {
    display: flex;
    justify-content: flex-end;
    gap: 0.65rem;
    margin-bottom: 0.9rem;
    flex-wrap: wrap;
}

.notification-sound-library-modal-list {
    display: grid;
    gap: 0.7rem;
    max-height: min(58vh, 560px);
    overflow: auto;
    padding-right: 0.2rem;
}

.notification-sound-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem;
    border: 1px solid var(--divider-color);
    border-radius: 12px;
    background: var(--input-bg);
}

.notification-sound-row.is-selected {
    border-color: color-mix(in srgb, var(--primary-blue) 42%, var(--border-color) 58%);
    background: color-mix(in srgb, var(--card-bg) 84%, var(--primary-blue) 16%);
}

.notification-sound-row-main {
    display: grid;
    gap: 0.34rem;
    min-width: 0;
}

.notification-sound-row-main strong {
    color: var(--heading-color);
}

.notification-sound-row-main > span {
    color: var(--muted-color);
    font-size: 0.78rem;
    overflow-wrap: anywhere;
}

.notification-sound-row-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.45rem;
}

.notification-sound-confirm-modal {
    width: min(520px, 92vw);
}

.notification-sound-delete-summary {
    display: grid;
    gap: 0.35rem;
    padding: 0.95rem;
    border: 1px solid color-mix(in srgb, var(--error-color, #dc3545) 34%, var(--border-color) 66%);
    border-radius: 12px;
    background: color-mix(in srgb, var(--card-bg) 84%, var(--error-color, #dc3545) 16%);
}

.notification-sound-delete-summary strong {
    color: var(--heading-color);
}

.notification-sound-delete-summary span {
    color: var(--muted-color);
    font-size: 0.82rem;
    overflow-wrap: anywhere;
}

.live-call-sound-card {
    border-color: color-mix(in srgb, var(--primary-blue, #003366) 22%, var(--border-color, #d9dee7));
}

.live-call-sound-card .settings-card-header {
    background: linear-gradient(135deg, color-mix(in srgb, var(--card-bg, #fff) 88%, var(--primary-blue, #003366) 12%), var(--card-bg, #fff));
    border-radius: 8px;
    padding: 0.75rem;
}

.live-call-sound-card .notification-sound-range output {
    min-width: 52px;
}

.notification-sound-library {
    display: grid;
    gap: 0.7rem;
}

.notification-sound-empty {
    border: 1px dashed var(--divider-color);
    border-radius: 12px;
    padding: 0.9rem 1rem;
    color: var(--muted-color);
    background: rgba(0, 51, 102, 0.04);
}

.notification-sound-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    border: 1px solid var(--divider-color);
    border-radius: 12px;
    padding: 0.85rem 0.95rem;
    background: var(--input-bg);
}

.notification-sound-item.is-selected {
    border-color: rgba(0, 51, 102, 0.32);
    background: rgba(0, 51, 102, 0.08);
    box-shadow: inset 0 0 0 1px rgba(0, 51, 102, 0.06);
}

.notification-sound-item-main {
    display: grid;
    gap: 0.45rem;
}

.notification-sound-item-main strong {
    color: var(--heading-color);
}

.notification-sound-item-side {
    display: grid;
    gap: 0.45rem;
    justify-items: end;
    color: var(--muted-color);
    font-size: 0.78rem;
    text-align: right;
}

.notification-sound-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
}

.notification-sound-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
    border: 1px solid var(--divider-color);
    background: rgba(255, 255, 255, 0.85);
    color: var(--muted-color);
    font-size: 0.75rem;
    font-weight: 600;
}

.settings-summary {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.summary-row {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.7rem 0.85rem;
    border-radius: 10px;
    border: 1px solid var(--divider-color);
    background: var(--input-bg);
}

.summary-label {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted-color);
}

.summary-value {
    color: var(--heading-color);
    font-weight: 600;
    font-size: 0.92rem;
}

.user-management-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
}

.user-management-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
}

.user-summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
}

.bulk-actions-bar {
    display: none;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.8rem 1rem;
    border-radius: 10px;
    background: linear-gradient(90deg, rgba(0, 51, 102, 0.08), rgba(212, 175, 55, 0.08));
    border: 1px solid var(--divider-color);
    box-shadow: 0 2px 6px var(--shadow-light);
    animation: fadeSlideIn 0.2s ease;
}

.bulk-actions-bar.active {
    display: flex;
}

@keyframes fadeSlideIn {
    from {
        opacity: 0;
        transform: translateY(-6px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.bulk-actions-info {
    font-size: 0.9rem;
    color: var(--text-color);
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.bulk-actions-buttons {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
}

.bulk-selected-summary {
    font-size: 0.8rem;
    color: var(--muted-color);
}

#selectAllFilteredBtn {
    display: none;
}

.user-summary-card {
    background: var(--card-bg);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    box-shadow: 0 2px 8px var(--shadow-light);
    display: flex;
    align-items: center;
    gap: 0.9rem;
}

.user-summary-icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--primary-blue);
    color: #fff;
    font-size: 1.2rem;
}

.user-summary-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--heading-color);
}

.user-summary-label {
    font-size: 0.85rem;
    color: var(--muted-color);
}

.user-filters {
    background: var(--card-bg);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    box-shadow: 0 2px 8px var(--shadow-light);
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
}

.user-search {
    flex: 1;
    min-width: 240px;
    position: relative;
}

.user-search input {
    width: 100%;
    padding: 0.65rem 2.5rem 0.65rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--input-bg);
    color: var(--text-color);
    font-size: 0.9rem;
}

.user-search .search-icon {
    position: absolute;
    right: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted-color);
}

.admin-search-results {
    position: fixed;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 14px;
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.18);
    padding: 0.4rem;
    display: grid;
    gap: 0.35rem;
    overflow-y: auto;
    z-index: 240;
}

.admin-search-results[hidden] {
    display: none;
}

.admin-search-result {
    display: grid;
    gap: 0.15rem;
    width: 100%;
    padding: 0.8rem 0.95rem;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 10px;
    text-align: left;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
}

.admin-search-result:hover,
.admin-search-result:focus-visible {
    background: rgba(13, 74, 153, 0.08);
    border-color: rgba(13, 74, 153, 0.16);
    transform: translateY(-1px);
    outline: none;
}

.admin-search-result-section {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--primary-blue);
}

.admin-search-result-title {
    font-size: 0.95rem;
    color: var(--heading-color);
}

.admin-search-result-description {
    font-size: 0.8rem;
    line-height: 1.45;
    color: var(--muted-color);
}

.admin-search-empty {
    display: grid;
    gap: 0.2rem;
    padding: 0.85rem 0.95rem;
    border-radius: 10px;
    background: rgba(148, 163, 184, 0.08);
    color: var(--muted-color);
    font-size: 0.82rem;
}

.settings-search-hit {
    outline: 2px solid rgba(203, 168, 112, 0.45);
    outline-offset: 2px;
    border-color: rgba(203, 168, 112, 0.55) !important;
    box-shadow: 0 0 0 3px rgba(203, 168, 112, 0.18), 0 16px 34px rgba(15, 23, 42, 0.08);
    background: linear-gradient(180deg, rgba(203, 168, 112, 0.12), rgba(255, 255, 255, 0.92));
    animation: adminSearchPulse 1.6s ease;
