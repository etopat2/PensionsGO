/* Security Overlays */
.security-overlay,
.access-denied-overlay,
.inactivity-warning,
.reauth-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    backdrop-filter: blur(10px);
}

.security-modal,
.access-denied-content,
.warning-content,
.reauth-modal {
    background: var(--card-bg);
    border-radius: 12px;
    text-align: center;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    border: 2px solid var(--primary-gold);
    max-width: 400px;
    width: 90%;
    padding: 2.5rem;
}

.security-icon,
.access-denied-icon,
.warning-icon,
.reauth-icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
}

.security-actions,
.access-denied-actions,
.warning-actions,
.form-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.5rem;
}

.security-btn,
.access-denied-btn,
.warning-btn,
.reauth-btn {
    padding: 0.75rem 2rem;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: 120px;
}

.security-btn-primary,
.access-denied-btn:not(.secondary),
.warning-btn.primary,
.reauth-btn.primary {
    background: var(--primary-maroon);
    color: white;
}

.security-btn-primary:hover,
.access-denied-btn:not(.secondary):hover,
.warning-btn.primary:hover,
.reauth-btn.primary:hover:not(:disabled) {
    background: var(--primary-maroon-dark);
    transform: translateY(-1px);
}

.security-btn-secondary,
.access-denied-btn.secondary,
.warning-btn.secondary,
.reauth-btn.secondary {
    background: var(--border-color);
    color: var(--text-color);
}

.security-btn-secondary:hover,
.access-denied-btn.secondary:hover,
.warning-btn.secondary:hover,
.reauth-btn.secondary:hover {
    background: var(--muted-color);
    color: white;
}

/* Loading states */
.admin-dashboard.loading {
    opacity: 0.6;
    pointer-events: none;
}

.loading-spinner {
    display: inline-block;
    width: 20px;
    height: 20px;
