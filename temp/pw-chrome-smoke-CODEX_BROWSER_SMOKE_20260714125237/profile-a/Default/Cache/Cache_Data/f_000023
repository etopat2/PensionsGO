          <strong>${escapeHtml(formatDashboardLabel(filters.focus))}</strong>
        </div>
        <div class="dashboard-data-modal-summary-item">
          <span>Living Status</span>
          <strong>${escapeHtml(filters.livingStatus || "Alive")}</strong>
