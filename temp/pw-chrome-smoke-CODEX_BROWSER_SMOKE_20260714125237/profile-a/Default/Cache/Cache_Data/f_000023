            <strong>${escapeHtml(formatAgeValue(summary.oldest?.ageYears))}</strong>
          </div>
          <div class="dashboard-data-modal-summary-item">
            <span>Youngest in View</span>
            <strong>${escapeHtml(formatAgeValue(summary.youngest?.ageYears))}</strong>
