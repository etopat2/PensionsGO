        <div class="dashboard-data-modal-summary-grid">
          <div class="dashboard-data-modal-summary-item">
            <span>Matched Rows</span>
            <strong>${escapeHtml(pluralize(summary.matchedCount || 0, "record"))}</strong>
          </div>
          <div class="dashboard-data-modal-summary-item">
