/* Base Card Style */
.card {
  background: var(--card-bg);
  border-radius: 10px;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
  padding: 1.2rem;
  text-align: left;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  flex-shrink: 0; /* Prevent cards from shrinking */
}

.card:hover {
  transform: translateY(-5px);
  box-shadow: 0 6px 14px rgba(0, 0, 0, 0.12);
}

.card h4 {
  margin-bottom: 0.5rem;
  font-size: 1rem;
  font-weight: 600;
  color: var(--heading-color);
  position: relative;
  left: 5%;
}

.card p {
  font-size: 1.6rem;
  font-weight: bold;
  margin: 0;
}

.card span {
  position: relative;
  right: 5%;
  text-align: right;
}

/* Card Color Themes*/
.card.blue {
  border-top: 4px solid #007bff;
  color: #007bff;
}

.card.green {
  border-top: 4px solid #28a745;
  color: #28a745;
}

.card.orange {
  border-top: 4px solid #ff9800;
  color: #ff9800;
}

.card.red {
  border-top: 4px solid #dc3545;
  color: #dc3545;
}

.card.teal {
  border-top: 4px solid #009688;
  color: #009688;
}

.card.purple {
  border-top: 4px solid #6f42c1;
  color: #6f42c1;
}

/* Staff Due cards: stack title then count, centered */
#staffDueSection .card {
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 0.35rem;
}

