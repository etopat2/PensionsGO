    flex: 0 0 auto;
  }

  .dataset-panel-actions {
    width: 100%;
    justify-content: flex-start;
    gap: 0.34rem;
  }

  .dataset-panel-actions .btn-action,
  .data-management-shell .btn-action {
    min-height: 33px;
    padding: 0.4rem 0.62rem;
    font-size: 0.72rem;
    border-radius: 9px;
    box-shadow: 0 6px 12px rgba(83, 22, 38, 0.12);
  }

  .data-metric-cards .card,
  .recycle-summary-cards .card {
    min-height: 80px;
    padding: 0.6rem 0.66rem 0.56rem;
    border-radius: 12px;
  }

  .data-metric-cards .card h4,
  .recycle-summary-cards .card h4 {
    font-size: 0.64rem;
  }

  .data-metric-cards .card p,
  .recycle-summary-cards .card p {
    font-size: clamp(0.9rem, 2vw, 1.04rem);
  }

  .data-metric-cards .card span,
  .recycle-summary-cards .card span {
    font-size: 0.64rem;
  }

  .data-management-table .action-col,
  .data-management-table td.action-col {
    display: none;
  }

  .data-management-row.is-actionable td {
    cursor: pointer;
  }

  .data-management-table-movements th,
  .data-management-table-movements td {
    text-align: left;
    vertical-align: top;
  }

  .feedback-workspace-guide,
  .feedback-detail-summary-grid,
  .feedback-detail-meta-grid,
  .feedback-workflow-grid {
    grid-template-columns: 1fr;
  }

  .feedback-detail-tabs {
    padding-inline: 1rem;
  }
}

@media (max-width: 640px) {
  .data-management-tabbar {
    gap: 0.32rem;
    padding: 0.28rem;
  }

  .data-management-tab {
    width: auto;
    justify-content: center;
    min-height: 32px;
    padding: 0.4rem 0.62rem;
    font-size: 0.7rem;
  }

  .data-metric-cards,
  .recycle-summary-cards {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.42rem;
  }

  .dataset-panel-actions {
    gap: 0.28rem;
  }

  .dataset-panel-actions .btn-action,
  .data-management-shell .btn-action {
    min-height: 32px;
    padding: 0.36rem 0.54rem;
    font-size: 0.68rem;
  }

  .recycle-filter-bar .dashboard-filter-actions,
  .data-filter-bar .dashboard-filter-actions {
    width: 100%;
  }
}

@media (max-width: 420px) {
  .data-metric-cards,
  .recycle-summary-cards,
  .recycle-filter-bar,
  .recycle-purge-grid,
  .data-filter-bar {
    grid-template-columns: 1fr;
  }

  .recycle-filter-bar .dashboard-filter-search,
  .data-filter-bar .dashboard-filter-search {
    grid-column: auto;
  }
}

/* 2026 Dashboard Restoration */
.dashboard-main {
  --dashboard-sidebar-width: clamp(15rem, 16vw, 17.25rem);
  --dashboard-bottom-gap: clamp(1rem, 2vw, 1.5rem);
  --dashboard-content-max-width: 1680px;
}

.sidebar {
  top: var(--main-header-height, 0px);
  height: calc(100vh - var(--main-header-height, 0px) - var(--main-footer-height, 0px));
  padding: 0 0.85rem 0.9rem;
  background: linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(245, 237, 228, 0.98));
  border-right: 1px solid var(--table-border);
  box-shadow: 14px 0 28px rgba(41, 26, 19, 0.08);
}

.sidebar-header {
  margin-bottom: 0.35rem;
  padding: 0 0.15rem 0.35rem;
  border-bottom: 1px solid color-mix(in srgb, var(--table-border) 88%, transparent 12%);
}

.sidebar-header h2 {
  display: flex;
  align-items: center;
  gap: 0.55rem;
  font-size: 1.05rem;
  color: var(--heading-color);
  border-bottom: 0;
  padding-bottom: 0;
}

.desktop-nav li {
  margin-top: 0;
  margin-bottom: 0.12rem;
}

.desktop-nav a {
  padding: 0.52rem 0.82rem;
  border-radius: 14px;
  font-size: 0.88rem;
  font-weight: 600;
  border-left: none;
  box-shadow: inset 0 0 0 1px transparent;
}

.desktop-nav a:hover {
  background: color-mix(in srgb, var(--primary-blue) 90%, #fff 10%);
  color: #fffaf2;
  border-left-color: transparent;
  transform: none;
  box-shadow: 0 10px 18px rgba(28, 51, 73, 0.12);
}

.desktop-nav a.active {
  background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-blue-dark) 100%);
  color: #fffaf2;
  border-left-color: transparent;
  box-shadow: 0 12px 24px rgba(28, 51, 73, 0.18);
}

.mobile-nav-select select {
  min-height: 44px;
  border-radius: 14px;
  border: 1px solid color-mix(in srgb, var(--border-color) 70%, var(--primary-blue) 30%);
  background: linear-gradient(180deg, var(--card-bg), var(--surface-soft));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
}

.sidebar-actions {
  gap: 0.5rem;
  margin-top: 1.25rem;
}

.btn-action {
  min-height: 40px;
  padding: 0.6rem 0.92rem;
  border-radius: 12px;
  background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-blue-dark) 100%);
  color: #fffaf2;
  box-shadow: 0 12px 22px rgba(28, 51, 73, 0.16);
}

.btn-action:hover {
  background: linear-gradient(135deg, color-mix(in srgb, var(--primary-blue) 94%, #000 6%) 0%, var(--primary-blue-dark) 100%);
}

.dashboard-content {
  padding: clamp(0.95rem, 1.8vw, 1.35rem);
}

.dashboard-header {
  margin-bottom: 0.8rem;
  padding: 0 0 1rem;
  border-bottom: 1px solid color-mix(in srgb, var(--table-border) 82%, transparent 18%);
}

.dashboard-header h1 {
  font-size: clamp(1.45rem, 1.1rem + 1vw, 1.95rem);
  font-weight: 800;
  color: var(--heading-color);
}

.dashboard-header p {
  color: var(--muted-color);
  max-width: 78ch;
}

.dashboard-live-strip {
  background: linear-gradient(180deg, color-mix(in srgb, var(--card-bg) 84%, var(--primary-gold) 16%), color-mix(in srgb, var(--card-bg) 92%, var(--surface-soft) 8%));
  border-color: color-mix(in srgb, var(--primary-gold) 56%, var(--border-color) 44%);
}

.cards-container {
  grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
  gap: 0.95rem;
}

.card {
  padding: 1rem 1.05rem;
  border-radius: 18px;
  border: 1px solid color-mix(in srgb, var(--table-border) 82%, transparent 18%);
  background: linear-gradient(180deg, var(--card-bg), var(--surface-soft));
  box-shadow: var(--card-shadow);
  gap: 0.7rem;
  min-height: 140px;
}

.card:hover {
  transform: translateY(-2px);
  box-shadow: var(--card-shadow-strong);
}

.card h4,
.general-summary-cards .card h4,
.data-metric-cards .card h4,
.recycle-summary-cards .card h4 {
  position: static;
  left: auto;
  margin: 0;
  font-size: 0.76rem;
  font-weight: 800;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--muted-color);
}

.card p,
.general-summary-cards .card p,
.data-metric-cards .card p,
.recycle-summary-cards .card p {
  margin: 0;
  font-size: clamp(1.35rem, 1.2vw, 1.8rem);
  color: var(--heading-color);
  line-height: 1.06;
  font-weight: 800;
}

.card span,
.general-summary-cards .card span,
.data-metric-cards .card span,
.recycle-summary-cards .card span {
  position: static;
  right: auto;
  color: var(--muted-color);
  font-size: 0.82rem;
  line-height: 1.45;
}

.card.blue {
  border-top: 4px solid var(--primary-blue);
}

.card.green {
  border-top: 4px solid var(--success-color);
}

.card.orange {
  border-top: 4px solid var(--primary-gold);
}

.card.red {
  border-top: 4px solid var(--error-color);
}

.card.teal {
  border-top: 4px solid color-mix(in srgb, var(--primary-blue) 72%, var(--success-color) 28%);
}

.card.purple {
  border-top: 4px solid color-mix(in srgb, var(--primary-maroon) 58%, var(--primary-blue) 42%);
}

.general-summary-cards .card {
  min-height: 150px;
}

.filter-group,
.data-filter-bar,
.recycle-filter-bar {
  gap: 0.75rem;
  padding: 0.82rem 0.9rem;
  border-radius: 16px;
  border: 1px solid var(--table-border);
  background: linear-gradient(180deg, var(--card-bg), var(--surface-soft));
  box-shadow: 0 10px 18px rgba(58, 33, 24, 0.07);
}

.filter-group label,
.dashboard-filter-field span {
  font-weight: 700;
  color: var(--label-color);
}

.filter-group select,
.filter-group input[type="text"],
.dashboard-filter-field input,
.dashboard-filter-field select {
  min-height: 42px;
  border-radius: 12px;
}

.dashboard-table-wrap {
  margin-top: 0.85rem;
  border-radius: 18px;
  border: 1px solid var(--table-border);
  box-shadow: var(--card-shadow);
}

.dashboard-data-table thead th {
  padding: 0.75rem 0.8rem;
  background: var(--table-head-bg);
  color: var(--heading-color);
}

.dashboard-data-table tbody td {
  padding: 0.72rem 0.8rem;
}

.dashboard-data-table tbody tr:hover,
.data-management-row.is-actionable:hover {
  background: var(--table-row-hover);
}

.data-management-header h2,
.dataset-panel-header h3 {
  color: var(--heading-color);
}

.data-management-tabbar {
  gap: 0.38rem;
  padding: 0.32rem;
  border-radius: 999px;
  background: linear-gradient(180deg, var(--card-bg), var(--surface-soft));
  border: 1px solid var(--table-border);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.74);
}

.data-management-tab {
  min-height: 34px;
  padding: 0.44rem 0.78rem;
  border-radius: 999px;
  border-color: transparent;
  background: transparent;
  color: var(--muted-color);
  box-shadow: none;
}

.data-management-tab:hover,
.data-management-tab:focus-visible {
  background: color-mix(in srgb, var(--primary-blue) 10%, var(--card-bg) 90%);
  color: var(--heading-color);
  box-shadow: none;
}

.data-management-tab.active {
  background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-blue-dark) 100%);
  color: #fffaf2;
  border-color: transparent;
  box-shadow: 0 10px 18px rgba(28, 51, 73, 0.18);
}

.dataset-panel-actions {
  gap: 0.35rem;
}

.data-management-shell .btn-action,
.dataset-panel-actions .btn-action,
.data-filter-bar .dashboard-filter-actions .btn-action,
.recycle-filter-bar .dashboard-filter-actions .btn-action {
  min-height: 34px;
  padding: 0.42rem 0.68rem;
  border-radius: 10px;
  font-size: 0.72rem;
}

.data-metric-cards .card,
.recycle-summary-cards .card {
  min-height: 128px;
  padding: 0.85rem 0.9rem;
  border-radius: 16px;
}

@media (max-width: 1024px) {
  .dashboard-main {
    margin-top: var(--main-header-height, 0px);
    height: calc(100vh - var(--main-header-height, 0px) - var(--main-footer-height, 0px));
  }

  .dashboard-wrapper {
    flex-direction: column;
    padding-left: 0;
  }

  .sidebar {
    position: relative;
    top: auto;
    left: auto;
    width: 100%;
    height: auto;
    max-height: 300px;
    padding: 0.95rem;
    box-shadow: none;
    border-right: none;
    border-bottom: 1px solid var(--border-color);
  }

  .dashboard-content {
    height: auto;
    min-height: 0;
    margin-left: 0;
  }
}

@media (max-width: 768px) {
  .dashboard-content {
    padding: 0.8rem;
  }

  .cards-container {
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  }

  .data-management-tabbar {
    flex-wrap: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .data-management-tabbar::-webkit-scrollbar {
    display: none;
  }
}

