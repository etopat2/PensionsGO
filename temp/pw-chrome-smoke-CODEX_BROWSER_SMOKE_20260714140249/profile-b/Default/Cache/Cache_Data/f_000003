}

.session-modal-header .session-warning-icon::before,
.session-modal-header .session-warning-icon::after {
  content: "";
  position: absolute;
  inset: 0;
  clip-path: polygon(50% 4%, 96% 92%, 4% 92%);
}

.session-modal-header .session-warning-icon::before {
  background: #000;
}

.session-modal-header .session-warning-icon::after {
  inset: 0.2rem;
  background: #facc15;
}

.session-modal-header .session-warning-icon span {
  position: absolute;
  left: 50%;
  top: 59%;
  transform: translate(-50%, -50%);
  color: #000;
  font-size: 2.35rem;
  font-weight: 1000;
  line-height: 1;
  z-index: 1;
}

.session-modal-header h2,
.session-modal-header h3 {
  margin: 0 !important;
  color: var(--session-modal-header-text) !important;
  -webkit-text-fill-color: currentColor !important;
  background: none !important;
  font-size: clamp(1.25rem, 1rem + 1vw, 1.65rem);
  line-height: 1.22;
  font-weight: 800;
}

.session-modal-body p {
  margin: 0 !important;
  padding: 0.85rem 0.95rem;
  border-radius: 14px;
  border: 1px solid color-mix(in srgb, var(--session-modal-accent) 18%, var(--border-color) 82%);
  background: color-mix(in srgb, var(--session-modal-accent-soft) 72%, #fff 28%);
  color: color-mix(in srgb, var(--heading-color) 82%, var(--session-modal-accent-dark) 18%) !important;
  font-size: 1rem;
  font-weight: 600;
  line-height: 1.6;
}

.session-overlay-buttons,
.warning-actions {
  margin-top: 0;
}

.session-overlay-buttons .session-btn-primary,
.warning-actions .warning-btn.primary,
.session-warning-overlay .btn-primary,
.inactivity-warning .btn-primary {
  background: linear-gradient(135deg, var(--session-modal-accent) 0%, var(--session-modal-accent-dark) 100%) !important;
  color: #fffaf2 !important;
  box-shadow: 0 12px 22px color-mix(in srgb, var(--session-modal-accent) 24%, transparent);
}

@media (max-width: 768px) {
  .logout-modal {
    padding: 1rem;
    border-radius: 18px;
  }

  .session-overlay-content,
  .session-warning-modal,
  .warning-content {
    border-radius: 18px;
  }

  .session-modal-header {
    padding: 1.15rem 1rem 1rem;
  }

  .session-modal-body {
    padding: 1rem;
  }

  .session-modal-header .session-icon,
  .session-modal-header .warning-icon {
    width: 3.45rem;
    height: 3.45rem;
    font-size: 2rem;
  }

  .session-modal-header .session-warning-icon span {
    font-size: 1.9rem;
  }

  .modal-actions {
    padding-top: 0.65rem;
  }
}

