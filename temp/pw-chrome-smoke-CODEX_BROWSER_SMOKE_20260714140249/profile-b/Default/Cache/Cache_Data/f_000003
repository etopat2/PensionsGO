/* Logout Modal & Overlay Styling*/
@import url("color-variables.css");
/* Dimmed background overlay */
.logout-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(10, 10, 10, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 3001;
  backdrop-filter: blur(3px);
  animation: fadeIn 0.3s ease;
}

/* Workflow form modals should sit above header/footer and below dropdown menus */
.workflow-modal-overlay {
  z-index: 3001;
  padding: 1rem;
}

.workflow-modal-overlay .logout-modal {
  max-height: 90vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Modal container */
.logout-modal {
  background: var(--card-bg, #fff);
  color: var(--text-color, #222);
  border-radius: 10px;
  padding: 2rem;
  width: 90%;
  max-width: 420px;
  text-align: center;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  animation: slideUp 0.3s ease;
}

.logout-modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.85rem;
  margin-bottom: 0.9rem;
  text-align: left;
}

.logout-modal-header > div {
  min-width: 0;
  flex: 1 1 auto;
}

/* Modal header text */
.logout-modal h3 {
  color: var(--heading-color, #333);
  margin-bottom: 0.8rem;
  font-size: 1.3rem;
  font-weight: 700;
}

.logout-modal-header h3 {
  margin: 0;
}

.logout-modal-header p {
  margin: 0.28rem 0 0;
  font-size: 0.92rem;
  color: var(--muted-color, #555);
}

/* Modal message */
.logout-modal p {
  font-size: 1rem;
  color: var(--muted-color, #555);
  margin-bottom: 1.5rem;
}

/* Action buttons */
.modal-actions {
  display: flex;
  justify-content: center;
  gap: 1rem;
  position: sticky;
  bottom: 0;
  z-index: 3;
  background: color-mix(in srgb, var(--card-bg, #fff) 95%, var(--menu-bg-dark, #000) 5%);
  border-top: 1px solid var(--border-color, #ddd);
  padding-top: 0.55rem;
}

.btn-confirm,
.btn-cancel {
  border: none;
  border-radius: 6px;
  padding: 0.6rem 1.2rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.25s ease;
}

.btn-confirm {
  background: var(--primary-color, #007bff);
  color: #fff;
}

.btn-confirm:hover {
  background: var(--primary-dark, #0056b3);
  transform: translateY(-2px);
}

.btn-cancel {
  background: var(--muted-color, #ccc);
  color: #333;
}

.btn-cancel:hover {
  background: #bbb;
  transform: translateY(-2px);
}

/* Logout overlay spinner (after confirmation) */
.logout-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(15, 15, 15, 0.8);
  color: #fff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 10000;
  text-align: center;
  font-size: 1.2rem;
  animation: fadeIn 0.4s ease;
}

.logout-overlay .spinner {
  width: 40px;
  height: 40px;
  border: 4px solid rgba(255, 255, 255, 0.4);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 1rem;
}

/* Session & Access Overlays*/
.session-overlay {
  position: fixed;
  inset: 0;
  min-height: 100dvh;
  padding: clamp(1rem, 3vw, 1.5rem);
  background: rgba(0, 0, 0, 0.75);
  display: grid;
  place-items: center;
  overflow-y: auto;
  overscroll-behavior: contain;
  z-index: var(--z-session-overlay, 2147483647);
  color: #fff;
  font-family: "Segoe UI", Roboto, sans-serif;
  animation: fadeIn 0.3s ease-in-out;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  isolation: isolate;
  box-sizing: border-box;
}

.session-overlay-content {
  background: linear-gradient(135deg, rgba(30, 30, 30, 0.95), rgba(50, 50, 50, 0.95));
  position: relative;
  z-index: 1;
  padding: 2.5rem 3rem;
  border-radius: 15px;
  text-align: center;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.1);
  max-width: 480px;
  width: min(480px, 100%);
  margin: auto;
  animation: slideUp 0.4s ease-out;
  max-height: min(88vh, calc(100dvh - 2rem));
  overflow-y: auto;
}

.session-warning-overlay,
.inactivity-warning {
  position: fixed;
  inset: 0;
  min-height: 100dvh;
  padding: clamp(1rem, 3vw, 1.5rem);
  background: rgba(0, 0, 0, 0.78);
  display: grid;
  place-items: center;
  overflow-y: auto;
  overscroll-behavior: contain;
  z-index: var(--z-session-overlay, 2147483647);
  color: #fff;
  isolation: isolate;
  box-sizing: border-box;
}

.session-warning-modal,
.warning-content {
  background: linear-gradient(135deg, rgba(32, 32, 32, 0.96), rgba(52, 52, 52, 0.96));
  position: relative;
  z-index: 1;
  padding: 2.25rem 2.5rem;
  border-radius: 15px;
  text-align: center;
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.45);
  border: 1px solid rgba(255, 255, 255, 0.12);
  width: min(460px, 100%);
  margin: auto;
  max-height: min(88vh, calc(100dvh - 2rem));
  overflow-y: auto;
}

.session-warning-modal h3,
.warning-content h3 {
  margin: 0.75rem 0 0;
  font-size: 1.55rem;
  color: #ffcc00;
}

.session-warning-modal p,
.warning-content p {
  margin: 1rem 0 0;
  font-size: 1.05rem;
  line-height: 1.6;
  color: #e8e8e8;
}

.warning-icon {
  display: block;
  font-size: 3rem;
  margin-bottom: 0.5rem;
}

.warning-actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 1.5rem;
}

.session-warning-modal .warning-btn,
.warning-content .warning-btn,
.session-warning-overlay .btn-primary,
.session-warning-overlay .btn-secondary,
.inactivity-warning .btn-primary,
.inactivity-warning .btn-secondary {
  min-width: 140px;
  padding: 0.8rem 1.4rem;
  border: none;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}

.session-warning-modal .warning-btn.primary,
.warning-content .warning-btn.primary,
.session-warning-overlay .btn-primary,
.inactivity-warning .btn-primary {
  background: linear-gradient(135deg, #ffcc00, #ffaa00);
  color: #111;
  box-shadow: 0 8px 18px rgba(255, 204, 0, 0.25);
}

.session-warning-modal .warning-btn.secondary,
.warning-content .warning-btn.secondary,
.session-warning-overlay .btn-secondary,
.inactivity-warning .btn-secondary {
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.session-warning-modal .warning-btn:hover,
.warning-content .warning-btn:hover,
.session-warning-overlay .btn-primary:hover,
.session-warning-overlay .btn-secondary:hover,
.inactivity-warning .btn-primary:hover,
.inactivity-warning .btn-secondary:hover {
  transform: translateY(-1px);
}

/* Keep modal sharp while background is blurred */
.session-expired-blur .session-overlay,
.session-expired-blur .session-overlay * {
  filter: none;
}

.session-icon {
  font-size: 3rem;
  margin-bottom: 1rem;
  animation: pulse 2s infinite;
}

.session-overlay h2 {
  margin-top: 0.5rem;
  font-size: 1.8rem;
  color: #ffcc00;
  font-weight: 600;
}

.session-overlay p {
  margin-top: 1rem;
  font-size: 1.1rem;
  color: #e0e0e0;
  line-height: 1.5;
  margin-bottom: 2rem;
}

.session-overlay-buttons {
  display: flex;
  gap: 1rem;
  justify-content: center;
  margin-top: 1rem;
}

.session-btn {
  padding: 0.8rem 2rem;
  border: none;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  min-width: 120px;
}

.session-btn-primary {
  background: linear-gradient(135deg, #ffcc00, #ffaa00);
  color: #000;
}

.session-btn-primary:hover {
  background: linear-gradient(135deg, #ffaa00, #ff8800);
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(255, 204, 0, 0.3);
}

.session-btn-primary:active {
  transform: translateY(0);
}

/* Blur effect for background when session expires */
.session-expired-blur main,
.session-expired-blur header,
.session-expired-blur footer,
.session-expired-blur .main-wrapper {
  filter: blur(5px);
  pointer-events: none;
  user-select: none;
  transition: filter 0.3s ease;
}

/* Ensure the blur effect works on all content */
.session-expired-blur body > *:not(.session-overlay) {
  filter: blur(5px);
  pointer-events: none;
}

/* Animations */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { 
    opacity: 0;
    transform: translateY(30px) scale(0.95);
  }
  to { 
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Responsive design */
@media (max-width: 768px) {
  .logout-modal {
    width: min(100%, 420px);
    padding: 1rem;
  }

  .logout-modal-header {
    align-items: flex-start;
  }

  .modal-actions {
    flex-wrap: wrap;
  }

  .modal-actions .btn-confirm,
  .modal-actions .btn-cancel {
    flex: 1 1 calc(50% - 0.5rem);
    min-width: 0;
  }

  .session-overlay-content {
    padding: 2rem 1.5rem;
    margin: 1rem;
  }
  
  .session-overlay h2 {
    font-size: 1.5rem;
  }
  
  .session-overlay p {
    font-size: 1rem;
  }
  
  .session-overlay-buttons {
    flex-direction: column;
    gap: 0.8rem;
  }
  
  .session-btn {
    width: 100%;
  }
}

