Options -Indexes
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule ^(?:backups|cache|exports|logs)(?:/|$) - [F,L]
RewriteRule ^uploads/(?:documents|messages|payroll|suspensions|accountability_forms)(?:/|$) - [F,L]
</IfModule>
<FilesMatch "^(config\.php|config\.local\.php|config\.local\.example\.php)$">
    Require all denied
</FilesMatch>
